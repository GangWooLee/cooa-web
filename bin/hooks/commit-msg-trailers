#!/usr/bin/env bash
# Claude 첨부 트레일러 완전성 검증 — 사람 커밋을 막지 않도록 스코핑:
#   · 두 트레일러 중 하나라도 있으면 → 둘 다 형식 맞게 있어야 통과(부분 첨부 금지).
#   · 트레일러가 전혀 없는 순수 사람 커밋은 통과.
# (전량 강제 STRICT 변형은 docs/harness.md 참고 — 사람 수동 커밋을 막으니 기본 비활성.)
set -uo pipefail
msg_file="${1:-$(git rev-parse --git-path COMMIT_EDITMSG)}"
[ -f "$msg_file" ] || exit 0
msg="$(cat "$msg_file")"

has_co=0;  printf '%s\n' "$msg" | grep -qE '^Co-Authored-By: Claude .+<.+>'                       && has_co=1
has_ses=0; printf '%s\n' "$msg" | grep -qE '^Claude-Session: https://claude\.ai/code/session_[A-Za-z0-9]+' && has_ses=1

[ $((has_co + has_ses)) -eq 0 ] && exit 0   # 순수 사람 커밋 — 검증 대상 아님

errs=()
[ "$has_co"  -eq 1 ] || errs+=("'Co-Authored-By: Claude … <…>' 트레일러 누락/형식오류")
[ "$has_ses" -eq 1 ] || errs+=("'Claude-Session: https://claude.ai/code/session_…' 트레일러 누락/형식오류")
if [ "${#errs[@]}" -gt 0 ]; then
  {
    echo "✗ commit-msg: Claude 트레일러 불완전 —"
    for e in "${errs[@]}"; do echo "    - $e"; done
    echo "  두 트레일러는 항상 함께 있어야 합니다(하나만 있으면 차단)."
  } >&2
  exit 1
fi
exit 0
