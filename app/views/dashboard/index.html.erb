<% content_for :title, "데이터 관리 - 대시보드" %>
<div class="flex h-full flex-col bg-white">
  <%# 헤더 %>
  <div class="border-b border-line-soft px-6 pt-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <%= ui_icon "grid", size: 20, klass: "text-cooa" %>
        <span class="text-[20px] font-bold text-ink">데이터 관리</span>
      </div>
      <div class="flex h-[33px] w-[520px] items-center gap-2 rounded-[11px] border-[1.5px] border-line px-3 text-line">
        <%= ui_icon "search", size: 18 %><span class="text-[14px]">콘텐츠 검색</span>
      </div>
    </div>
    <nav class="mt-3 flex items-center gap-7 text-[15px]">
      <span class="border-b-2 border-cooa pb-2 font-bold text-cooa">대시보드</span>
      <span class="cursor-default pb-2 text-ink/60">타임라인</span>
      <span class="cursor-default pb-2 text-ink/60">칸반뷰</span>
    </nav>
  </div>

  <%# 액션 툴바 %>
  <div class="flex items-center gap-2 px-6 py-3">
    <button class="bg-cooa-gradient flex items-center gap-1.5 rounded-lg px-3 py-2 text-[14px] font-bold text-white">
      <%= ui_icon "upload", size: 16, stroke: 2 %> 새 파일 올리기 <%= ui_icon "caret", size: 15 %>
    </button>
    <button class="flex items-center gap-1.5 rounded-lg bg-accent px-3 py-2 text-[14px] font-bold text-cooa">
      <%= ui_icon "plus", size: 16, stroke: 2 %> 규칙 만들기 <%= ui_icon "caret", size: 15 %>
    </button>
    <div class="ml-3 flex items-center gap-4 text-ink/80">
      <span class="flex items-center gap-1 text-[14px]"><%= ui_icon "user", size: 18 %> 담당자</span>
      <span class="flex items-center gap-1 text-[14px]"><%= ui_icon "filter", size: 18 %> 필터</span>
      <span class="flex items-center gap-1 text-[14px]"><%= ui_icon "sort", size: 18 %> 순서</span>
    </div>
  </div>

  <%# 제품 트리 테이블 %>
  <div class="flex-1 overflow-auto px-6 pb-10" data-controller="tree-table">
    <table class="w-full border-collapse text-[14px]">
      <thead class="sticky top-0 z-10">
        <tr class="bg-tint text-ink">
          <% ["제품","품목코드","국가","채널","담당자","단상자","용기","인서트지","바코드","기타","기한"].each do |h| %>
            <th class="whitespace-nowrap border-y border-line-soft px-3 py-2 text-left font-bold"><%= h %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @rows.each do |node, depth| %>
          <%= render "dashboard/row", node: node, depth: depth %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
