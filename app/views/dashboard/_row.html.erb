<%# 대시보드 행 — 폴더: 행 클릭=트리 토글 / 리프: 행 클릭=상세 드로어 프레임 로드 %>
<%
  row_data = { "tree-table-target": "row", "node-id": node.id, "depth": depth }
  if node.folder?
    row_data[:action] = "click->tree-table#toggle"
  else
    row_data[:controller] = "row-link"
    row_data[:action] = "click->row-link#go"
  end
%>
<%= content_tag :tr, data: row_data, class: "group cursor-pointer border-b border-line-soft hover:bg-accent/30" do %>
  <td class="whitespace-nowrap py-2.5 pr-3" style="padding-left: <%= 10 + depth * 20 %>px">
    <div class="flex items-center gap-1">
      <%# └ 트리 커넥터 (루트 외) %>
      <% if depth > 0 %>
        <span class="relative mr-0.5 inline-block h-[18px] w-3.5 shrink-0">
          <span class="absolute left-0 top-0 h-1/2 border-l border-line-soft"></span>
          <span class="absolute left-0 top-1/2 w-3 border-t border-line-soft"></span>
        </span>
      <% end %>

      <% if node.folder? %>
        <span class="tree-caret shrink-0 text-line transition-transform"><%= ui_icon "caret", size: 15 %></span>
        <%= ui_icon "folder", size: 16, klass: "shrink-0 text-cooa" %>
        <span class="text-[14px] font-bold text-ink"><%= node.name %></span>
        <span class="ml-1 text-[12px] text-line">· 하위 <%= node.children.size %></span>
      <% else %>
        <span class="inline-block w-[15px] shrink-0"></span>
        <%= ui_icon "doc", size: 15, klass: "shrink-0 text-line" %>
        <%= link_to node.name, product_path(node),
              data: { turbo_frame: "detail", turbo_action: "advance", "row-link-target": "link" },
              class: "text-[14px] text-ink hover:text-cooa" %>
      <% end %>
    </div>
  </td>

  <%# SKU/메타/구성요소 칩 — 리프(leaf)만 채움 %>
  <td class="whitespace-nowrap px-3 py-2.5 font-medium text-ink"><%= node.code %></td>
  <td class="px-3 py-2.5 text-ink"><%= node.country_label if node.leaf? && node.country.present? %></td>
  <td class="px-3 py-2.5 text-ink"><%= node.channel if node.leaf? %></td>
  <td class="px-3 py-2.5">
    <% if node.leaf? %>
      <div class="flex -space-x-1.5"><% node.product_members.each do |pm| %><%= avatar(pm.user, size: 22) %><% end %></div>
    <% end %>
  </td>
  <% %w[outer_box container insert barcode etc].each do |type| %>
    <td class="px-3 py-2.5">
      <% if node.leaf? && (comp = node.components.detect { |c| c.component_type == type }) && (v = comp.current_version) %>
        <%= link_to component_version_path(v), title: "#{v.vlabel.upcase} 파일 보기",
              class: "inline-block rounded-md transition hover:ring-2 hover:ring-cooa/40" do %><%= version_chip(v.vlabel, size: 22) %><% end %>
      <% end %>
    </td>
  <% end %>
  <td class="whitespace-nowrap px-3 py-2.5 text-ink/80">
    <% if node.leaf? && node.deadline %>
      <span class="inline-flex items-center gap-1"><%= ui_icon "calendar", size: 15 %> <%= node.deadline.strftime("%Y.%m.%d") %></span>
    <% end %>
  </td>
<% end %>
