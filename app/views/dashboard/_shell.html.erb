<%# 대시보드 셸 = 트리 리스트 + 우측 상세 드로어(비모달 슬라이드오버).
     locals: detail_product (nil이면 빈 프레임 = 드로어 닫힘) %>
<% detail_product = local_assigns[:detail_product] %>
<div data-controller="detail-drawer" class="relative h-full min-w-0 overflow-hidden">
  <%= render "dashboard/list" %>

  <%# 우측 상세 드로어 — 기본 화면 밖(translate-x-full), 콘텐츠 로드 시 슬라이드 인 %>
  <aside data-detail-drawer-target="panel"
         class="absolute right-0 top-0 z-20 flex h-full w-full max-w-[680px] translate-x-full flex-col border-l border-line bg-white shadow-2xl transition-transform duration-300 ease-out">
    <%= turbo_frame_tag "detail", class: "flex min-h-0 flex-1 flex-col" do %>
      <% if detail_product %>
        <%= render "products/detail", product: detail_product %>
      <% end %>
    <% end %>
    <%# 프레임 fetch 중 로딩 스피너(states-1) — Turbo [busy] 기반 CSS로만 표시(위 .drawer-loading 규칙),
        콘텐츠 도착 시 자연 은닉. 항상 DOM에 존재(기본 display:none)하므로 프레임 로드 지연 시 즉시 뜬다. %>
    <div class="drawer-loading pointer-events-none absolute inset-0 items-center justify-center bg-white" aria-hidden="true">
      <span class="spinner text-display text-cooa"></span>
    </div>
  </aside>
</div>
