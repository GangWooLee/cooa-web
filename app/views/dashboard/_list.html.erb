<%# 대시보드 트리 리스트 (헤더+툴바+테이블) — index / 상세 셸 공용. @rows 사용 %>
<div data-controller="tree tree-ctx" data-tree-create-url-value="<%= products_path %>" data-tree-workspace-id-value="<%= current_workspace&.id %>" data-tree-ctx-rename-param-value="rename" class="flex h-full min-w-0 flex-col bg-white">
  <%# 헤더 — 타이틀 = 작업실명(current_workspace_label · 홈은 별도 _workspaces가 "데이터 관리"). 우상단 = 멤버
      어포던스 팝오버(작업실 진입 화면 @workspace에서만). 제품 풀페이지(products#show)도 이 헤더를 그 작업실명으로
      렌더(current_workspace가 @product에서 도출). nil 방어 폴백 "데이터 관리". %>
  <div class="border-b border-line-soft px-6 pb-4 pt-4">
    <div class="flex min-w-0 items-center justify-between gap-3">
      <div class="flex min-w-0 items-center gap-2">
        <%= ui_icon "layers", size: 20, klass: "shrink-0 text-cooa" %>
        <span class="truncate text-display font-bold text-ink"><%= current_workspace_label || "데이터 관리" %></span>
      </div>
      <% if @workspace %><%= render "dashboard/brand_header" %><% end %>
    </div>
  </div>

  <%# 액션 툴바 — 첫 행동(새 폴더/새 파일). 선택 노드 기준(폴더→자식 / 파일→형제 / 미선택→루트 맨 아래).
      아이콘+텍스트 라벨로 승격(빈 상태 문구의 "새 폴더·새 파일"과 명칭 일치). %>
  <div class="flex min-w-0 flex-wrap items-center gap-2 px-6 py-3">
    <button type="button" data-action="tree#newFolder" title="새 폴더"
            class="bg-cooa-gradient flex items-center gap-1.5 rounded-lg px-3 py-2 text-note font-semibold text-white transition hover:opacity-90">
      <%= ui_icon "folder", size: 16 %> 새 폴더
    </button>
    <button type="button" data-action="tree#newItem" title="새 파일"
            class="flex items-center gap-1.5 rounded-lg border border-line-soft bg-white px-3 py-2 text-note font-semibold text-cooa transition hover:border-cooa hover:bg-tint">
      <%= ui_icon "doc", size: 16 %> 새 파일
    </button>
    <%# 로드맵(규칙·담당자·필터·정렬)은 가짜 비활성 컨트롤 6개 대신 1줄 표기로 축약 — 첫 행동에 집중. %>
    <span class="ml-auto text-caption text-muted">곧 제공 · 규칙 · 담당자 · 필터 · 정렬</span>
  </div>

  <%# 제품 트리 테이블 — 좁은 폭에서 가로 스크롤. 빈 작업실은 860px 테이블 크롬(불필요한 가로 스크롤 유발)
      대신 빈 상태 카드만 렌더 — 첫 폴더/항목 유도(D3). 위 툴바의 "새 폴더/새 파일"이 이 작업실에 귀속. %>
  <div class="min-w-0 flex-1 overflow-auto px-6 pb-10" data-controller="tree-table tree-dnd">
    <% if @workspace && @rows.empty? %>
      <div class="mx-auto mt-10 max-w-md rounded-2xl border border-line-soft bg-white px-6 py-14 text-center shadow-sm">
        <div class="flex flex-col items-center gap-2">
          <%= ui_icon "folder", size: 32, klass: "text-muted" %>
          <p class="text-note font-medium text-ink">아직 폴더나 항목이 없습니다</p>
          <p class="text-body text-muted">위의 <b>새 폴더</b>·<b>새 파일</b>로 이 작업실의 첫 항목을 만들어 보세요<% if @can_manage_workspace %> — 위 헤더의 <b>＋ 멤버 초대·관리</b>에서 멤버도 초대할 수 있습니다<% end %>.</p>
        </div>
      </div>
    <% else %>
      <div class="min-w-0 overflow-x-auto">
        <table class="w-full min-w-[860px] border-collapse text-note">
          <thead class="sticky top-0 z-10">
            <tr class="bg-tint text-ink">
              <% ["제품","품목코드","국가","채널","담당자","구성요소","기한"].each do |h| %>
                <th class="whitespace-nowrap border-y border-line-soft px-3 py-2 text-left font-bold"><%= h %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @rows.each do |node, depth| %>
              <%= render "dashboard/row", node: node, depth: depth %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

  <%= render "shared/tree_context_menu" %>
</div>
