<%# 대시보드 트리 리스트 (헤더+툴바+테이블) — index / 상세 셸 공용. @rows 사용 %>
<div class="flex h-full min-w-0 flex-col bg-white">
  <%# 헤더 %>
  <div class="border-b border-line-soft px-6 pt-4">
    <div class="flex min-w-0 items-center justify-between">
      <div class="flex min-w-0 items-center gap-2">
        <%= ui_icon "grid", size: 20, klass: "text-cooa" %>
        <span class="truncate text-[20px] font-bold text-ink">데이터 관리</span>
      </div>
    </div>
    <nav class="mt-3 flex items-center gap-7 overflow-x-auto text-[15px]">
      <span class="whitespace-nowrap border-b-2 border-cooa pb-2 font-bold text-cooa">대시보드</span>
      <span class="cursor-not-allowed whitespace-nowrap pb-2 text-ink/60 opacity-60" title="준비 중">타임라인</span>
      <span class="cursor-not-allowed whitespace-nowrap pb-2 text-ink/60 opacity-60" title="준비 중">칸반뷰</span>
    </nav>
  </div>

  <%# 액션 툴바 — 미구현 항목은 정직한 비활성(준비 중) %>
  <div class="flex min-w-0 flex-wrap items-center gap-2 px-6 py-3">
    <button type="button" disabled title="준비 중"
            class="bg-cooa-gradient flex cursor-not-allowed items-center gap-1.5 rounded-lg px-3 py-2 text-[14px] font-bold text-white opacity-60">
      <%= ui_icon "upload", size: 16, stroke: 2 %> 새 파일 올리기 <%= ui_icon "caret", size: 15 %>
    </button>
    <button type="button" disabled title="준비 중"
            class="flex cursor-not-allowed items-center gap-1.5 rounded-lg bg-accent px-3 py-2 text-[14px] font-bold text-cooa opacity-60">
      <%= ui_icon "plus", size: 16, stroke: 2 %> 규칙 만들기 <%= ui_icon "caret", size: 15 %>
    </button>
    <div class="ml-3 flex items-center gap-4 text-ink/80">
      <span class="flex cursor-not-allowed items-center gap-1 text-[14px] opacity-60" title="준비 중"><%= ui_icon "user", size: 18 %> 담당자</span>
      <span class="flex cursor-not-allowed items-center gap-1 text-[14px] opacity-60" title="준비 중"><%= ui_icon "filter", size: 18 %> 필터</span>
      <span class="flex cursor-not-allowed items-center gap-1 text-[14px] opacity-60" title="준비 중"><%= ui_icon "sort", size: 18 %> 순서</span>
    </div>
  </div>

  <%# 제품 트리 테이블 — 좁은 폭에서 가로 스크롤 %>
  <div class="min-w-0 flex-1 overflow-auto px-6 pb-10" data-controller="tree-table">
    <div class="min-w-0 overflow-x-auto">
      <table class="w-full min-w-[860px] border-collapse text-[14px]">
        <thead class="sticky top-0 z-10">
          <tr class="bg-tint text-ink">
            <% ["제품","품목코드","국가","채널","담당자","단상자","용기","인서트지","바코드","기타","기한"].each do |h| %>
              <th class="whitespace-nowrap border-y border-line-soft px-3 py-2 text-left font-bold"><%= h %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @rows.each do |node, depth| %>
            <%= render "dashboard/row", node: node, depth: depth %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
