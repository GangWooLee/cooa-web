<%# 헤더 우측 멤버 어포던스(W3) — /workspaces/:id 진입 화면(@workspace)에서만 렌더. 트리거 = 스코프 멤버 아바타
    스택(≤3) + 인원수(접근 이름은 aria-label). 클릭 = <dialog> 모달(새 작업실 모달과 동형 — dialog 컨트롤러 ·
    native Esc/백드롭). 모달 본문: 발급 링크 배너(최상단) → 멤버 목록 → 대기 초대 → (관리자) 사람 추가(제안
    combobox → /workspace_memberships가 동료면 즉시 추가·미지면 초대 자동 분기). flash[:invite_link] 있으면 자동
    열림(발급 직후 링크 노출 — dialog#connect openValue). 비관리자 = 읽기 전용(멤버 목록만). %>
<div data-controller="dialog" data-dialog-open-value="<%= flash[:invite_link].present? %>" class="shrink-0">
  <button type="button" data-action="dialog#open"
          aria-label="<%= @can_manage_workspace ? "멤버 초대·관리" : "작업실 멤버 보기" %>"
          class="flex min-h-[36px] cursor-pointer items-center gap-2 rounded-lg border border-line-soft bg-white px-2.5 py-1 transition hover:border-cooa/40 hover:bg-tint">
    <% if @workspace_members.any? %>
      <div class="flex -space-x-1.5">
        <% @workspace_members.first(3).each do |acc| %><%= avatar(acc.user, size: 24) %><% end %>
      </div>
      <span class="text-meta font-medium text-ink"><%= @workspace_members.size %>명</span>
    <% else %>
      <%= ui_icon "user", size: 16, klass: "text-muted" %>
      <span class="text-meta font-medium text-muted">멤버</span>
    <% end %>
    <% if @can_manage_workspace %><%= ui_icon "plus", size: 14, klass: "shrink-0 text-cooa" %><% end %>
  </button>

  <dialog data-dialog-target="dialog"
          class="m-auto w-full max-w-md rounded-2xl border border-line bg-white p-0 shadow-2xl backdrop:bg-ink/40">
    <div class="flex max-h-[80vh] flex-col">
      <div class="flex items-center justify-between border-b border-line-soft px-5 py-4">
        <div class="min-w-0">
          <div class="text-section font-bold text-ink">작업실 멤버</div>
          <p class="mt-0.5 truncate text-meta text-muted"><%= @workspace.name %></p>
        </div>
        <button type="button" data-action="dialog#close" aria-label="닫기"
                class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-ink/50 transition hover:bg-ink/5 hover:text-ink">
          <%= ui_icon "x", size: 18 %>
        </button>
      </div>
      <div class="min-h-0 flex-1 space-y-4 overflow-auto px-5 py-4">
        <%# 발급 직후 초대 링크(1회 노출) — 모달 최상단(자동 열림과 짝). %>
        <%= render "shared/invite_link_banner" %>
        <%= render "dashboard/workspace_members" %>
      </div>
      <div class="flex items-center justify-end border-t border-line-soft px-5 py-3">
        <%= ui_button "닫기", variant: :ghost, data: { action: "dialog#close" } %>
      </div>
    </div>
  </dialog>
</div>
