<%# 작업실 멤버 모달 본문(_brand_header 다이얼로그가 소유). 멤버 목록(아바타·한글 역할 배지 · 관리자는 스코프
    grant 회수 ×) → 대기 초대(관리자·취소) → 사람 추가(관리자 · 제안 combobox → /workspace_memberships가 서버에서
    "동료 즉시 추가 / 미지 이메일 초대"를 자동 분기). 비관리자 = 멤버 목록만(읽기 전용). 발급 링크 배너는 모달
    상단(호출측). 스코프는 hidden으로 이 작업실(@workspace)에 고정되고 서버가 authorize_member_write!로 재확인. %>
<div class="space-y-4">
  <%# ── 멤버 목록 — 아바타 · 한글 역할 배지 · (관리자) 이 작업실 스코프 grant 회수 × ── %>
  <div>
    <div class="mb-1.5 text-meta font-bold text-ink">멤버<% if @workspace_members.any? %> (<%= @workspace_members.size %>)<% end %></div>
    <% if @workspace_members.any? %>
      <div class="divide-y divide-line-soft rounded-lg border border-line-soft">
        <% @workspace_members.each do |acc| %>
          <%# 배지 = 활성·비-tenant-wide 스코프 역할. 관리자(subtree_ids 有)면 이 작업실 소속 RA로 좁혀 회수 ×를
              올바른 RA에 건다. 비관리자(subtree_ids nil)는 스코프 배지 전부(읽기 전용 요약). %>
          <% ras = acc.role_assignments.select { |ra| ra.active? && !ra.tenant_wide? }
             ras = ras.select { |ra| ra.scope_workspace_id == @workspace.id || @workspace_subtree_ids.include?(ra.scope_product_id || ra.scope_component&.product_id) } if @workspace_subtree_ids %>
          <div class="flex items-center gap-2 px-3 py-2 text-meta">
            <%= avatar(acc, size: 22, ring: false) %>
            <span class="min-w-0 flex-1 truncate font-medium text-ink"><%= acc.name || acc.email %></span>
            <% ras.each do |ra| %>
              <span class="inline-flex items-center gap-1 rounded bg-accent px-1.5 py-0.5 text-caption font-medium text-cooa" title="<%= role_description(ra.role_key) %>">
                <%= role_label(ra.role_key) %>
                <% if @can_manage_workspace %>
                  <%= button_to "×", role_assignment_path(ra), method: :delete, params: { return_to_workspace: @workspace.id },
                        form: { class: "inline-block leading-none", data: { turbo_confirm: "#{acc.name || acc.email}님을 #{@workspace.name} 작업실에서 제외할까요?" } },
                        class: "cursor-pointer px-0.5 leading-none text-cooa/60 transition hover:text-cooa" %>
                <% end %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-meta text-muted">이 작업실에 지정된 멤버가 없습니다 — 회사 전체 역할 멤버가 관리합니다.</p>
    <% end %>
  </div>

  <% if @can_manage_workspace %>
    <%# ── 대기 중 초대(서브트리 스코프 필터) — 취소 ── %>
    <% if @workspace_pending.any? %>
      <div>
        <div class="mb-1.5 text-meta font-bold text-ink">대기 중인 초대 (<%= @workspace_pending.size %>)</div>
        <div class="divide-y divide-line-soft rounded-lg border border-line-soft">
          <% @workspace_pending.each do |inv| %>
            <div class="flex items-center gap-2 px-3 py-2 text-meta">
              <span class="min-w-0 flex-1 truncate font-medium text-ink"><%= inv.email %></span>
              <span class="rounded bg-tint px-1.5 py-0.5 text-caption text-muted" title="<%= role_description(inv.role_key) %>"><%= role_label(inv.role_key) %></span>
              <span class="text-caption text-muted"><%= inv.expires_at.strftime("%m.%d") %>까지</span>
              <%= button_to "취소", invitation_path(inv), method: :delete, params: { return_to_workspace: @workspace.id },
                    form: { data: { turbo_confirm: "#{inv.email} 초대를 취소할까요?" } },
                    class: ui_button_classes(variant: :ghost, size: :sm) %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── 사람 추가 — 이메일 입력(제안 combobox) + 역할 4종. 서버(/workspace_memberships)가 동료(addable 후보)면
        즉시 추가, 처음 보는 이메일이면 초대 링크 발급으로 자동 분기(자유 입력 허용 — 목록은 편의 제안). ── %>
    <div class="border-t border-line-soft pt-4">
      <div class="mb-1.5 text-meta font-bold text-ink">사람 추가</div>
      <div data-controller="combobox">
        <%= form_with url: workspace_memberships_path, method: :post, class: "space-y-2" do %>
          <%= hidden_field_tag :scope_workspace_id, @workspace.id %>
          <%= hidden_field_tag :return_to_workspace, @workspace.id %>
          <div>
            <input type="text" name="email" required autocomplete="off" placeholder="이름 또는 이메일 입력"
                   role="combobox" aria-expanded="false" aria-autocomplete="list" aria-controls="member-suggest"
                   data-combobox-target="input"
                   data-action="focus->combobox#open input->combobox#filter keydown->combobox#keydown"
                   class="w-full rounded-lg border border-line-soft px-3 py-2 text-body focus:border-cooa focus:outline-none focus:ring-1 focus:ring-cooa">
            <ul role="listbox" id="member-suggest" data-combobox-target="list"
                class="mt-1 hidden max-h-44 divide-y divide-line-soft overflow-auto rounded-lg border border-line-soft">
              <% @workspace_addable.each do |acc| %>
                <li role="option" data-combobox-target="option" data-email="<%= acc.email %>"
                    data-search="<%= "#{acc.name} #{acc.email}".downcase %>" data-action="click->combobox#choose"
                    class="flex cursor-pointer items-center gap-2 px-3 py-1.5 text-meta transition hover:bg-tint">
                  <%= avatar(acc, size: 20, ring: false) %>
                  <span class="min-w-0 flex-1 truncate"><span class="font-medium text-ink"><%= acc.name || acc.email %></span> <span class="text-muted"><%= acc.email %></span></span>
                  <span class="shrink-0 rounded bg-accent px-1.5 py-0.5 text-caption font-bold text-cooa">동료 · 즉시 추가</span>
                </li>
              <% end %>
              <% @workspace_invite_suggestions.each do |email| %>
                <li role="option" data-combobox-target="option" data-email="<%= email %>"
                    data-search="<%= email.downcase %>" data-action="click->combobox#choose"
                    class="flex cursor-pointer items-center gap-2 px-3 py-1.5 text-meta transition hover:bg-tint">
                  <span class="min-w-0 flex-1 truncate text-ink"><%= email %></span>
                  <span class="shrink-0 rounded bg-tint px-1.5 py-0.5 text-caption font-bold text-muted">이전 초대</span>
                </li>
              <% end %>
            </ul>
          </div>
          <%= render "shared/role_picker", keys: Authz::RoleLabels::WORKSPACE_ROLE_KEYS, selected: "contributor" %>
          <p class="text-caption text-muted">초대 링크는 <strong>7일간 유효</strong>하며, 수락 후에는 관리자가 제외하기 전까지 멤버로 유지됩니다.</p>
          <div class="flex justify-end">
            <%= ui_button "추가", type: "submit" %>
          </div>
        <% end %>
      </div>
      <p class="mt-1.5 text-caption text-muted">동료는 바로 추가되고, 처음 보는 이메일은 초대 링크가 발급됩니다.</p>
    </div>
  <% end %>
</div>
