<% content_for :title, "계정 설정" %>
<div class="mx-auto w-full max-w-3xl p-6">
  <div class="mb-1 text-display font-bold text-ink">계정 설정</div>
  <p class="mb-6 text-body text-muted">내 프로필 표시 정보와 계정·보안을 관리합니다.</p>

  <%# ── 프로필(편집) — 이름·아바타 색·직무. 전부 accounts 컬럼(tenant-scoped·표시 선호). ── %>
  <%= form_with url: settings_path, method: :patch, class: "mb-6 rounded-xl border border-line p-4" do %>
    <div class="mb-3 text-section font-bold text-ink">프로필</div>

    <div class="flex items-center gap-4">
      <%= avatar(current_account, size: 56, ring: false) %>
      <div class="min-w-0 flex-1">
        <label class="block text-caption font-bold text-muted">이름</label>
        <%# 원 컬럼 기준 — 폴백 해석값을 그대로 영속하지 않는다(리뷰 F1). 비우고 저장 = 기본값으로 복귀. %>
        <input type="text" name="account[display_name]" value="<%= current_account[:display_name] %>" maxlength="80"
               placeholder="<%= current_account.user&.name || "이름" %>"
               class="mt-1 w-full rounded-lg border border-line-soft px-3 py-2 text-body focus:border-cooa focus:outline-none focus:ring-1 focus:ring-cooa">
        <p class="mt-1 text-caption text-muted">비워 두면 기본 이름을 사용합니다.</p>
      </div>
    </div>

    <div class="mt-4">
      <label class="block text-caption font-bold text-muted">아바타 색</label>
      <div class="mt-1.5 flex flex-wrap gap-2">
        <% Account::AVATAR_SWATCHES.each do |hex| %>
          <label class="relative cursor-pointer">
            <input type="radio" name="account[avatar_color]" value="<%= hex %>" class="peer sr-only"
                   <%= "checked" if current_account.avatar_color.to_s.casecmp?(hex) %>>
            <span class="block h-8 w-8 rounded-full ring-2 ring-transparent ring-offset-2 transition peer-checked:ring-cooa"
                  style="background:<%= hex %>" title="<%= hex %>"></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="mt-4">
      <label class="block text-caption font-bold text-muted">직무 <span class="font-normal">(표시용 — 권한과 무관)</span></label>
      <%# 원 컬럼 기준 + 빈 옵션(리뷰 F1): 미선택 상태에서 저장해도 첫 옵션이 자의로 영속되지 않고,
          "기본값 사용"으로 언제든 원복 가능. 빈 문자열은 모델 normalizes가 nil로 정규화. %>
      <select name="account[job_title]"
              class="mt-1 rounded-lg border border-line-soft px-3 py-2 text-body focus:border-cooa focus:outline-none focus:ring-1 focus:ring-cooa">
        <%= options_for_select([ [ "— 기본값 사용 —", "" ] ] + User::ROLE_LABELS.map { |k, v| [ v, k ] }, current_account[:job_title]) %>
      </select>
    </div>

    <div class="mt-5 flex justify-end">
      <%= ui_button "저장", type: "submit" %>
    </div>
  <% end %>

  <%# ── 계정 정보(읽기전용) — IdP 소유·변경 불가. ── %>
  <div class="mb-6 rounded-xl border border-line p-4">
    <div class="mb-3 text-section font-bold text-ink">계정 정보</div>
    <dl class="divide-y divide-line-soft text-body">
      <div class="flex items-center justify-between py-2">
        <dt class="text-muted">로그인 이메일</dt>
        <dd class="font-medium text-ink"><%= current_account.email %></dd>
      </div>
      <div class="flex items-center justify-between py-2">
        <dt class="text-muted">로그인 방식</dt>
        <dd class="font-medium text-ink"><%= current_account.idp_provider == "google_oauth2" ? "Google" : (current_account.idp_provider.presence || "—") %></dd>
      </div>
      <div class="flex items-center justify-between py-2">
        <dt class="text-muted">소속 조직</dt>
        <dd class="font-medium text-ink"><%= @organization.name %> <span class="text-meta text-muted"><%= @organization.region %></span></dd>
      </div>
    </dl>
    <p class="mt-2 text-caption text-muted">이메일·로그인 방식·조직은 로그인 제공자와 관리자가 관리합니다.</p>
  </div>

  <%# ── 보안 — 세션. ── %>
  <div class="rounded-xl border border-line p-4">
    <div class="mb-3 text-section font-bold text-ink">보안</div>
    <div class="flex flex-wrap items-center justify-between gap-3 py-1">
      <div>
        <div class="text-body font-medium text-ink">이 기기에서 로그아웃</div>
        <div class="text-caption text-muted">지금 이 브라우저 세션만 종료합니다.</div>
      </div>
      <%= button_to "로그아웃", session_path, method: :delete, class: ui_button_classes(variant: :secondary, size: :sm) %>
    </div>
    <div class="mt-2 flex flex-wrap items-center justify-between gap-3 border-t border-line-soft py-3">
      <div>
        <div class="text-body font-medium text-ink">모든 기기에서 로그아웃</div>
        <div class="text-caption text-muted">다른 모든 브라우저·기기의 세션을 즉시 무효화합니다(이 기기 포함).</div>
      </div>
      <%= button_to "전체 로그아웃", sign_out_all_path, method: :post,
            form: { data: { turbo_confirm: "모든 기기에서 로그아웃할까요? 다시 로그인해야 합니다." } },
            class: ui_button_classes(variant: :danger, size: :sm) %>
    </div>
  </div>
</div>
