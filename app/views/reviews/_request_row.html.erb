<%# 리뷰 인박스 행(Segment A/B 공용). locals: req, claimable. claimable=true(B)면 인라인 "내가 맡기" 버튼. %>
<% cv = req.component_version %>
<li>
  <div class="flex items-center gap-3 rounded-lg border border-line-soft p-3 transition hover:border-cooa">
    <%= link_to component_version_path(cv), class: "flex min-w-0 flex-1 items-center justify-between gap-3" do %>
      <div class="min-w-0">
        <div class="flex items-center gap-2 text-body">
          <%= product_code_chip(cv.product.code, extra: "shrink-0") %>
          <span class="truncate font-bold text-ink"><%= cv.component.display_name %> <%= cv.vlabel %></span>
        </div>
        <div class="mt-1 truncate text-meta text-muted"><%= cv.product.name %></div>
      </div>
      <div class="flex shrink-0 items-center gap-1.5 text-meta text-muted">
        요청자 <%= avatar(req.submitter, size: 18) %> <span class="text-ink"><%= req.submitter.name %></span>
        <span class="ml-1"><%= req.requested_at&.strftime("%m.%d") %></span>
        <%# 마감일 배지(있을 때만). 남은 기한=D-n, 초과=warn 색+아이콘+"n일 지남"(3중 신호). end_of_day 의미는
            req.overdue?가 보존(정렬은 requested_at ASC 불변, due는 표시 전용). overdue 행당 span.text-warn 정확히 1. %>
        <% if req.due_at %>
          <% od = req.overdue?; dd = (req.due_at.to_date - Date.current).to_i %>
          <span class="ml-1 inline-flex items-center gap-0.5 rounded px-1.5 py-0.5 text-caption font-bold <%= od ? "text-warn bg-warn/10" : "text-muted bg-tint" %>"
                title="마감일 <%= req.due_at.strftime("%-m.%-d") %><%= " · 초과" if od %>">
            <% if od %><%= ui_icon "warn", size: 11 %><%= -dd %>일 지남<% else %>D-<%= dd %><% end %>
          </span>
        <% end %>
      </div>
    <% end %>
    <% if claimable %>
      <%= button_to "내가 맡기", claim_approval_request_path(req), form: { class: "shrink-0" },
            class: ui_button_classes(variant: :primary, size: :sm, extra: "shrink-0") %>
    <% end %>
  </div>
</li>
