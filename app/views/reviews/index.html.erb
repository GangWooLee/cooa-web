<% content_for :title, "내게 요청된 리뷰" %>
<div class="flex h-full flex-col">
  <div class="flex items-center justify-between border-b border-line-soft px-6 py-3">
    <h1 class="text-display font-bold text-ink">내게 요청된 리뷰 <span class="text-muted">(<%= @assigned.size %>)</span></h1>
  </div>

  <%# 본문 좌우 패딩을 헤더(px-6)와 정렬 — 좌측 기준선 통일(spacing-2). 세로 여백은 유지. %>
  <div class="min-h-0 flex-1 overflow-auto px-6 py-4">
    <%# ── Segment A: 내게 요청된 리뷰(내가 지정 리뷰어) ── %>
    <% if @assigned.any? %>
      <%# 브랜드 필터(2개 이상일 때만) — Segment B와 동일 칩 패턴, A 전용 param :abrand %>
      <% if @assigned_inbox.brand_options.size > 1 %>
        <div class="mb-3 flex flex-wrap items-center gap-1.5 text-meta">
          <%= link_to "전체", reviews_path,
                class: "rounded-full px-2.5 py-1 font-medium transition #{@assigned_inbox.active_filter.nil? ? "bg-cooa text-white" : "bg-tint text-muted hover:text-cooa"}" %>
          <% @assigned_inbox.brand_options.each do |b| %>
            <%= link_to b.name, reviews_path(abrand: b.id),
                  class: "rounded-full px-2.5 py-1 font-medium transition #{@assigned_inbox.active_filter == b.id ? "bg-cooa text-white" : "bg-tint text-muted hover:text-cooa"}" %>
          <% end %>
        </div>
      <% end %>
      <ul class="space-y-2">
        <%= render partial: "request_row", collection: @assigned_inbox.requests, as: :req, locals: { claimable: false } %>
      </ul>
    <% else %>
      <%= render "shared/empty_state", variant: :card, icon: "bell",
            title: "요청된 리뷰가 없습니다",
            description: "회원님이 리뷰어로 지정되면 여기에 표시됩니다." %>
    <% end %>

    <%# ── Segment B: 리뷰어 미배정 — 내가 맡을 수 있는 리뷰(적격 owner/approver만) ── %>
    <% if @eligible %>
      <div class="mt-8 border-t border-line-soft pt-5">
        <h2 class="mb-3 text-section font-bold text-ink">리뷰어 미배정 <span class="font-medium text-muted">— 내가 맡을 수 있는 리뷰</span></h2>
        <%# 상한 초과 안내(컨트롤러 UNASSIGNED_CAP 절단) — 가장 오래된 순 상위만 렌더 중임을 명시. %>
        <% if @unassigned_overflow %>
          <div class="mb-3 rounded-md bg-tint px-3 py-2 text-meta text-muted">가장 오래된 <%= ReviewsController::UNASSIGNED_CAP %>건 표시 중 — 브랜드 필터로 좁혀 주세요.</div>
        <% end %>
        <% if @inbox.any? %>
          <%# 브랜드(루트 제품) 필터 %>
          <div class="mb-3 flex flex-wrap items-center gap-1.5 text-meta">
            <%= link_to "전체", reviews_path,
                  class: "rounded-full px-2.5 py-1 font-medium transition #{@inbox.active_filter.nil? ? 'bg-cooa text-white' : 'bg-tint text-muted hover:text-cooa'}" %>
            <% @inbox.brand_options.each do |b| %>
              <%= link_to b.name, reviews_path(brand: b.id),
                    class: "rounded-full px-2.5 py-1 font-medium transition #{@inbox.active_filter == b.id ? 'bg-cooa text-white' : 'bg-tint text-muted hover:text-cooa'}" %>
            <% end %>
          </div>
          <%# 브랜드 그룹(펼침 기본) %>
          <div class="space-y-3">
            <% @inbox.groups.each do |group| %>
              <details open class="rounded-lg border border-line-soft">
                <summary class="cursor-pointer px-3 py-2 text-meta font-bold text-ink"><%= group.brand.name %> <span class="text-muted">(<%= group.requests.size %>)</span></summary>
                <ul class="space-y-2 px-3 pb-3">
                  <%= render partial: "request_row", collection: group.requests, as: :req, locals: { claimable: true } %>
                </ul>
              </details>
            <% end %>
          </div>
        <% else %>
          <%= render "shared/empty_state", variant: :text, title: "맡을 수 있는 미배정 리뷰가 없습니다." %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
