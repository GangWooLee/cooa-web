<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "COOA 로그인" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-tint text-ink font-sans antialiased">
    <main class="flex min-h-full flex-col items-center justify-center gap-3 p-6">
      <%# auth 레이아웃 공통 flash(notice/alert) — 로그인·초대 수락 랜딩(invitation_acceptances)의 유일한 렌더
          지점. application 레이아웃과 동형(COOA 토큰). sessions/new은 자체 flash 블록을 제거해 중복을 방지. %>
      <% if flash[:notice].present? || flash[:alert].present? %>
        <div class="w-full max-w-md space-y-2">
          <% if flash[:notice].present? %>
            <div role="status" class="rounded-xl border border-line-soft bg-tint px-4 py-3 text-[13px] text-ink"><%= flash[:notice] %></div>
          <% end %>
          <% if flash[:alert].present? %>
            <div role="alert" class="rounded-xl border border-warn bg-tint px-4 py-3 text-[13px] font-medium text-ink"><%= flash[:alert] %></div>
          <% end %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
