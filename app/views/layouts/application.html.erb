<!DOCTYPE html>
<%# 쿠키로 사이드바 접힘 상태를 서버 렌더(무깜빡임 — 첫 페인트부터 올바른 상태) %>
<html class="h-full <%= 'sidebar-collapsed' if cookies[:cooa_sidebar] == '1' %>">
  <head>
    <title><%= content_for(:title) || "COOA" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-tint text-ink font-sans antialiased">
    <div class="flex h-screen flex-col overflow-hidden" data-controller="sidebar">
      <%= render "shared/topbar" %>
      <div class="flex min-h-0 flex-1">
        <%= render "shared/sidebar" %>
        <main class="min-w-0 flex-1 overflow-auto">
          <%# 일반 flash(notice/alert) — grant UI·claim 등 모든 리다이렉트 메시지의 유일한 렌더 지점. invite_link는
              members가 전용 블록에서 렌더하므로 여기서 제외. auth 레이아웃은 sessions/new이 자체 렌더라 미포함. %>
          <% if flash[:notice].present? || flash[:alert].present? %>
            <div class="space-y-2 px-6 pt-6">
              <% if flash[:notice].present? %>
                <div role="status" class="rounded-xl border border-line-soft bg-tint px-4 py-3 text-[13px] text-ink"><%= flash[:notice] %></div>
              <% end %>
              <% if flash[:alert].present? %>
                <div role="alert" class="rounded-xl border border-warn bg-tint px-4 py-3 text-[13px] font-medium text-ink"><%= flash[:alert] %></div>
              <% end %>
            </div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
