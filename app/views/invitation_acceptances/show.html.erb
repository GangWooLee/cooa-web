<% content_for :title, "COOA 초대" %>
<div class="w-full max-w-md rounded-2xl border border-line bg-white p-8 shadow-sm">
  <div class="text-[22px] font-bold text-ink">COOA</div>

  <% if @invitation %>
    <p class="mb-1 mt-3 text-section font-semibold text-ink">
      <% case @invitation.scope_type
         when "workspace" %>
        <%= @invitation.scope_workspace&.name %> 작업실에 초대되었습니다
      <% when "product" %>
        <%= @invitation.scope_product&.name %> 제품에 초대되었습니다
      <% else %>
        <%= @organization.name %>에 초대되었습니다
      <% end %>
    </p>
    <%# 결정 정보(발급 이메일·역할·참여 대상)는 text-ink로 승격 — 수락 판단의 근거. 역할은 배지 + 1줄 설명 상시. %>
    <p class="mb-6 text-body text-ink">
      <b><%= @invitation.email %></b> 로 발급된 초대입니다 — 같은 이메일의 Google 계정으로 계속하세요.
      수락하면 <span class="rounded bg-accent px-1.5 py-0.5 text-meta font-bold text-cooa"><%= role_label(@invitation.role_key) %></span><% if (desc = role_description(@invitation.role_key)).present? %> <span class="text-muted">(<%= desc %>)</span><% end %> 역할로
      <% case @invitation.scope_type
         when "workspace" %>
        <b class="text-cooa"><%= @invitation.scope_workspace&.name %></b> 작업실에 참여합니다.
      <% when "product" %>
        <b class="text-cooa"><%= @invitation.scope_product&.name %></b> 제품에 참여합니다.
      <% else %>
        모든 작업실에 접근하는 정식 멤버가 됩니다.
      <% end %>
    </p>

    <% if ENV["GOOGLE_CLIENT_ID"].present? %>
      <%# turbo:false 필수 — 교차출처(구글) 리다이렉트를 Turbo가 못 따라감. 주 CTA=primary(버건디 채움 + 흰 G칩). %>
      <%= button_to "/auth/google_oauth2", method: :post, form: { data: { turbo: false } },
            class: ui_button_classes(variant: :primary, size: :md, extra: "w-full") do %>
        <span class="flex size-5 shrink-0 items-center justify-center rounded-full bg-white">
          <svg width="13" height="13" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
        </span>
        Google로 계속
      <% end %>
    <% else %>
      <p class="rounded-lg bg-tint px-3 py-2 text-body text-muted">Google 로그인이 아직 설정되지 않았습니다 — 관리자에게 문의하세요.</p>
    <% end %>
    <p class="mt-4 text-caption text-muted">초대는 발급된 이메일의 소유자만 수락할 수 있으며 1회 사용 후 만료됩니다.</p>
  <% else %>
    <%# 무효/만료/회수 — 사유 미구분(열거 방지) %>
    <p class="mb-2 mt-3 text-section font-semibold text-ink">유효하지 않은 초대입니다</p>
    <p class="mb-6 text-body text-muted">링크가 만료되었거나 이미 사용되었을 수 있습니다. 초대한 분에게 새 링크를 요청하세요.</p>
    <%= link_to "로그인으로", new_session_path, class: "text-body font-semibold text-cooa" %>
  <% end %>
</div>
