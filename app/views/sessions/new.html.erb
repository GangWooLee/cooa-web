<% content_for :title, "COOA лЎңк·ёмқё" %>
<div class="w-full max-w-md rounded-2xl border border-line bg-white p-8 shadow-sm">
  <div class="text-[22px] font-bold text-ink">COOA</div>
  <p class="mb-6 mt-1 flex items-center gap-1.5 text-[14px] text-line">
    лҚ°лӘЁ кі„м •мқ„ м„ нғқн•ҙ лЎңк·ёмқён•ҳм„ёмҡ”
    <span class="rounded bg-tint px-1.5 py-0.5 text-[11px]">лҚ°лӘЁ</span>
  </p>

  <% if flash[:alert] %>
    <p class="mb-4 rounded-lg bg-red-50 px-3 py-2 text-[13px] text-red-700"><%= flash[:alert] %></p>
  <% end %>

  <div class="flex flex-col gap-2">
    <% @accounts.each do |account| %>
      <%= button_to session_path, params: { account_id: account.id }, method: :post,
            class: "flex w-full items-center gap-3 rounded-xl border border-line px-4 py-3 text-left transition hover:border-cooa hover:bg-tint" do %>
        <span class="flex size-9 shrink-0 items-center justify-center rounded-full text-[13px] font-bold text-white"
              style="background: <%= account.avatar_color || "#888" %>"><%= account.role_short %></span>
        <span class="min-w-0">
          <span class="block truncate text-[15px] font-semibold text-ink"><%= account.name %></span>
          <span class="block truncate text-[12px] text-line"><%= account.role_label %> В· <%= account.email %></span>
        </span>
      <% end %>
    <% end %>
  </div>

  <%# мҶҢм…ң/SSO лЎңк·ёмқё вҖ” м„Өм •лҗң providerл§Ң л…ём¶ң. лӘЁл‘җ POST(omniauth-rails_csrf_protection, CVE-2015-9284). %>
  <% if ENV["GOOGLE_CLIENT_ID"].present? || ENV["KC_ISSUER"].present? %>
    <div class="mt-4 flex flex-col gap-2 border-t border-line pt-4">
      <% if ENV["GOOGLE_CLIENT_ID"].present? %>
        <%# turbo:false н•„мҲҳ вҖ” Turboк°Җ нҸј м ңм¶ңмқ„ к°ҖлЎңмұ„л©ҙ кө¬кёҖ(көҗм°Ём¶ңмІҳ)лЎңмқҳ 302 лҰ¬лӢӨмқҙл үнҠёлҘј лӘ» л”°лқјк°җ %>
        <%= button_to "/auth/google_oauth2", method: :post, form: { data: { turbo: false } },
              class: "flex w-full items-center justify-center gap-2 rounded-xl border border-line bg-white px-4 py-3 text-[14px] font-semibold text-ink transition hover:border-cooa hover:bg-tint" do %>
          <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
          GoogleлЎң лЎңк·ёмқё
        <% end %>
      <% end %>
      <% if ENV["KC_ISSUER"].present? %>
        <%= button_to "KeycloakлЎң лЎңк·ёмқё", "/auth/openid_connect", method: :post, form: { data: { turbo: false } },
              class: "flex w-full items-center justify-center rounded-xl bg-ink px-4 py-3 text-[14px] font-semibold text-white transition hover:opacity-90" %>
      <% end %>
    </div>
  <% end %>
</div>
