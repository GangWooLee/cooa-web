<% content_for :title, "COOA 로그인" %>
<% google = ENV["GOOGLE_CLIENT_ID"].present? %>
<div class="w-full max-w-md rounded-2xl border border-line bg-white p-8 shadow-sm">
  <%= image_tag "cooa/logo.png", class: "h-7 w-auto", alt: "COOA" %>
  <p class="mb-6 mt-1 text-note text-muted">검토·결재 워크스페이스에 로그인하세요</p>

  <%# flash[:alert]는 auth 레이아웃이 렌더(중복 방지). %>

  <div class="flex flex-col gap-2.5">
    <%# 소셜/SSO — 설정된 provider만 노출. 모두 POST(omniauth-rails_csrf_protection, CVE-2015-9284).
        Google=주 CTA(primary·최상단). %>
    <% if google %>
      <%# turbo:false 필수 — Turbo가 폼 제출을 가로채면 구글(교차출처)로의 302 리다이렉트를 못 따라감 %>
      <%= button_to "/auth/google_oauth2", method: :post, form: { data: { turbo: false } },
            class: ui_button_classes(variant: :primary, size: :md, extra: "w-full") do %>
        <span class="flex size-5 shrink-0 items-center justify-center rounded-full bg-white">
          <svg width="13" height="13" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
        </span>
        Google로 로그인
      <% end %>
    <% end %>
    <% if ENV["KC_ISSUER"].present? %>
      <%= button_to "Keycloak로 로그인", "/auth/openid_connect", method: :post, form: { data: { turbo: false } },
            class: ui_button_classes(variant: :secondary, size: :md, extra: "w-full") %>
    <% end %>

    <%# 데모 계정(비prod 전용 — 컨트롤러 ensure_local_login_enabled). Google 미설정(dev/test/no-SSO)이면 유일
        경로이므로 펼쳐 노출, Google 설정 시엔 접어 부차화(system_sign_in 헬퍼는 접힘도 방어적으로 펼침). %>
    <details data-role="demo-accounts" class="rounded-xl border border-line-soft" <%= "open" unless google %>>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-2 px-4 py-3 text-note font-medium text-ink hover:bg-tint">
        <span class="flex items-center gap-1.5">
          데모 계정으로 둘러보기
          <span class="rounded bg-tint px-1.5 py-0.5 text-caption text-muted">데모</span>
        </span>
        <%= ui_icon "caret", size: 16, klass: "tree-caret text-muted" %>
      </summary>
      <div class="flex flex-col gap-2 border-t border-line-soft p-3">
        <% @accounts.each do |account| %>
          <%= button_to session_path, params: { account_id: account.id }, method: :post,
                class: "flex w-full items-center gap-3 rounded-xl border border-line-soft px-4 py-3 text-left transition hover:border-cooa hover:bg-tint" do %>
            <span class="flex size-9 shrink-0 items-center justify-center rounded-full text-body font-bold text-white"
                  style="background: <%= account.avatar_color || "var(--color-muted)" %>"><%= account.role_short %></span>
            <span class="min-w-0">
              <span class="block truncate text-lead font-semibold text-ink"><%= account.name %></span>
              <span class="block truncate text-meta text-muted"><%= account.role_label %> · <%= account.email %></span>
            </span>
          <% end %>
        <% end %>
      </div>
    </details>
  </div>
</div>
