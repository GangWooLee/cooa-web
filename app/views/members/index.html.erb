<% content_for :title, "구성원" %>
<div class="mx-auto w-full max-w-3xl p-6">
  <div class="mb-1 text-[20px] font-bold text-ink">구성원</div>
  <p class="mb-5 text-[13px] text-line">구성원과 대기 중인 초대를 한눈에 봅니다. 회사 전체 역할은 모든 작업실에 접근하고, 작업실 멤버는 소속 배지로 표시됩니다. <b>작업실 인원 추가·제외는 각 작업실 페이지</b>에서 하세요 — 여기서는 모든 작업실 접근 초대와 계정 현황을 관리합니다.</p>

  <%= render "shared/invite_link_banner" %>

  <%# 전사 초대 폼 — tenant-wide admin 전용. email + 역할(모든 작업실 접근). 작업실 한정 초대는 각 작업실 페이지. %>
  <% if @can_issue_tenant_wide %>
    <%= form_with url: invitations_path, method: :post, class: "mb-6 rounded-xl border border-line p-3" do %>
      <div class="mb-2 text-[12px] font-bold text-ink">모든 작업실 접근 멤버 초대 <span class="font-normal text-line">— 회사 전체 역할로 참여합니다</span></div>
      <div class="flex flex-wrap items-end gap-2">
        <div class="min-w-0 flex-1">
          <label class="block text-[11px] font-bold text-line">이메일</label>
          <input type="email" name="email" required placeholder="teammate@company.com"
                 class="mt-1 w-full rounded-lg border border-line-soft px-3 py-2 text-[13px] focus:border-cooa focus:outline-none">
        </div>
        <div>
          <label class="block text-[11px] font-bold text-line">역할</label>
          <select name="role_key" class="mt-1 rounded-lg border border-line-soft px-2 py-2 text-[13px]">
            <%= role_option_tags(Invitation::INVITABLE_ROLE_KEYS, selected: "contributor") %>
          </select>
        </div>
        <button type="submit" class="cursor-pointer rounded-lg bg-cooa-gradient px-4 py-2 text-[13px] font-bold text-white">초대 만들기</button>
      </div>
    <% end %>
  <% elsif @can_manage %>
    <%# scoped admin: 전사 초대 불가 — 작업실 단위 초대는 작업실 페이지에서. %>
    <div class="mb-6 rounded-xl border border-line-soft bg-tint/40 p-3 text-[12px] text-line">
      멤버 초대는 각 작업실 페이지에서 진행하세요 — 왼쪽 사이드바에서 작업실을 열어 "멤버 초대·관리"를 사용합니다.
    </div>
  <% end %>

  <%# 대기 중 초대 %>
  <% if @invitations.any? %>
    <div class="mb-2 text-[13px] font-bold text-ink">대기 중인 초대 (<%= @invitations.size %>)</div>
    <div class="mb-6 divide-y divide-line-soft rounded-xl border border-line">
      <% @invitations.each do |inv| %>
        <div class="flex items-center gap-3 px-3 py-2.5 text-[13px]">
          <span class="min-w-0 flex-1 truncate font-medium text-ink"><%= inv.email %></span>
          <span class="rounded bg-tint px-1.5 py-0.5 text-[11px] text-line" title="<%= role_description(inv.role_key) %>"><%= role_label(inv.role_key) %></span>
          <span class="text-[11px] text-line"><%= inv.expires_at.strftime("%m.%d") %>까지</span>
          <% if @can_manage %>
            <%= button_to "취소", invitation_path(inv), method: :delete,
                  form: { data: { turbo_confirm: "#{inv.email} 초대를 취소할까요?" } },
                  class: "cursor-pointer rounded px-2 py-1 text-[12px] text-line transition hover:bg-tint hover:text-cooa" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# 멤버 로스터 — tenant-wide 역할 배지 + 소속 작업실 배지(회수·작업실 추가) %>
  <div class="mb-2 text-[13px] font-bold text-ink">멤버 (<%= @accounts.size %>)</div>
  <div class="divide-y divide-line-soft rounded-xl border border-line">
    <% @accounts.each do |acc| %>
      <% active_ras = acc.role_assignments.select(&:active?) %>
      <div class="px-3 py-2.5 text-[13px]">
        <div class="flex items-center gap-3">
          <%= avatar(acc.user, size: 26, ring: false) %>
          <span class="min-w-0 flex-1 truncate">
            <span class="font-medium text-ink"><%= acc.name || acc.email %></span>
            <span class="ml-1 text-[12px] text-line"><%= acc.email %></span>
          </span>
          <%# tenant-wide 역할(전 조직 적용) %>
          <% active_ras.select(&:tenant_wide?).map(&:role_key).uniq.each do |rk| %>
            <span class="rounded bg-tint px-1.5 py-0.5 text-[11px] text-line" title="<%= role_description(rk) %>"><%= role_label(rk) %></span>
          <% end %>
          <span class="rounded-full px-2 py-0.5 text-[11px] font-bold <%= acc.active? ? "text-white" : "text-line bg-tint" %>"
                <%= 'style=background:#5f8f2e'.html_safe if acc.active? %>><%= acc.status %></span>
        </div>

        <%# 소속 작업실 배지(스코프 grant) — 읽기전용 + 작업실 링크. 회수·추가는 각 작업실 페이지에서(D5). %>
        <% scoped = active_ras.reject(&:tenant_wide?) %>
        <% if scoped.any? %>
          <div class="mt-2 flex flex-wrap items-center gap-1.5 pl-9">
            <% scoped.each do |ra| %>
              <% ws = workspace_for(ra, @workspace_by_id, @workspace_id_of) %>
              <span class="inline-flex items-center gap-1 rounded bg-accent px-1.5 py-0.5 text-[11px] font-medium text-cooa" title="<%= role_description(ra.role_key) %>">
                <%= role_label(ra.role_key) %> ·
                <% if ws %><%= link_to ws.name, workspace_path(ws), data: { turbo: false }, class: "underline decoration-cooa/30 underline-offset-2 transition hover:decoration-cooa" %>
                <% else %><%= workspace_name_for(ra, @workspace_by_id, @workspace_id_of) %><% end %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
