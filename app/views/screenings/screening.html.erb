<% content_for :title, "인허가 스크리닝 · #{@product.code}" %>
<% fboxes = @run ? finding_boxes(@run.screening_findings) : [] %>
<% box_seq = {}; fboxes.each { |b| box_seq[b[:finding_id]] = b[:seq] } %>
<%# 스크리닝 컨트롤러는 최상위 래퍼에 — 결과 패널과 하단 재실행 폼을 함께 감싸(폼 submit->screening#onRerun 배선).
    artwork-viewer:focus는 버블링으로 최상위까지 도달(Stimulus dispatch bubbles:true). %>
<div class="flex h-full flex-col" data-controller="screening"
     data-action="artwork-viewer:focus->screening#onFocus"
     data-screening-just-ran-value="<%= params[:ran].present? %>">
  <%# 헤더 + 주의문 %>
  <div class="flex flex-wrap items-center justify-between gap-2 border-b border-line-soft px-6 py-3">
    <div class="text-note"><%= node_breadcrumb(@product, trailing: "#{@version.component.display_name} #{@version.vlabel} 인허가 스크리닝") %></div>
    <div class="text-meta text-muted">AI의 답변은 완벽하지 않으니 꼭 RA 담당자의 검토를 권합니다.</div>
  </div>

  <div class="flex min-h-0 flex-1 flex-col overflow-auto lg:overflow-hidden lg:flex-row">
    <%# 좌: 아트워크 + finding 박스 (방금 실행 시 스캔 애니메이션) %>
    <div class="screening-artwork-pane relative min-w-0 flex-1 p-3 <%= "screening-scanning" if params[:ran] %>">
      <% if artwork?(@version) %>
        <%# 줌 활성(세 아트워크 뷰 일관) — finding 박스는 stage %-자식이라 줌 transform과 함께 이동/확대(좌표 정합).
            스캔 빔 오버레이는 pane 절대배치·pointer-events-none·초기 실행 시에만이라 줌과 독립. %>
        <%= render "shared/artwork_viewer", image_src: artwork_src(@version),
              is_pdf: @version.artwork_pdf?, thumb_src: artwork_thumb_src(@version),
              worker_src: asset_path("pdfjs.worker.min.js"),
              boxes: fboxes, zoom: true %>
        <%# 스캔 빔 오버레이 — 방금 실행 시 JS가 표시 후 애니메이션 %>
        <div data-screening-target="scanner" class="pointer-events-none absolute inset-3 z-20 hidden overflow-hidden rounded-xl">
          <div class="scan-line"></div>
        </div>
      <% else %>
        <div class="flex h-full items-center justify-center rounded-xl border border-line bg-tint-2 text-muted">아트워크 이미지 없음 · <%= @version.component.display_name %> <%= @version.vlabel %></div>
      <% end %>
    </div>

    <%# 우: 결과 패널 %>
    <aside class="flex w-full shrink-0 flex-col border-t border-line bg-white lg:min-h-0 lg:w-[400px] lg:border-l lg:border-t-0">
      <div class="border-b border-line-soft p-3">
        <%# 라이브 라벨 — 서버는 항상 "스크리닝 결과"로 렌더(reduced-motion·비-ran 안전). ran 스캔 동안만 JS가
            "스크리닝 중…"으로 바꿨다가 완료 시 되돌린다. %>
        <h3 data-screening-target="label" class="text-section font-bold text-ink">스크리닝 결과</h3>
        <% if @run %>
          <%# reorder(nil): drop association default order(:position) — PG rejects ORDER BY cols not in GROUP BY %>
          <% counts = @run.screening_findings.reorder(nil).group(:decision).count %>
          <%# 판정 요약 칩 — ran이면 초기 숨김(스포일러 방지) 후 카드 스태거 뒤 페이드인(리빌 마지막 단계) %>
          <div data-screening-target="summary" class="mt-2 flex flex-wrap items-center gap-1.5 <%= "opacity-0" if params[:ran] %>">
            <% Decidable::DECISIONS.each do |key, meta| %>
              <% next if key == "ok" %>
              <% n = counts[key] || 0 %>
              <% on = n.positive? %>
              <% signal = on ? meta[:color] : "var(--color-line-soft)" %>
              <span class="inline-flex items-center gap-1.5 rounded-lg border border-line-soft border-l-4 px-2.5 py-1 text-body font-bold"
                    style="border-left-color:<%= signal %>;color:<%= on ? (meta[:text] || "var(--color-ink)") : "var(--color-muted)" %>;background:<%= on ? meta[:bg] : "var(--color-tint)" %>">
                <%= meta[:label] %>
                <span class="flex h-[18px] min-w-[18px] items-center justify-center rounded border bg-white px-1 text-meta text-ink" style="border-color:<%= signal %>"><%= n %></span>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="space-y-2 overflow-visible p-3 lg:min-h-0 lg:flex-1 lg:overflow-auto">
        <%# 목적=위반 탐지 → '적합'(ok)은 노출하지 않음 %>
        <% issues = @run ? @run.screening_findings.reject(&:decision_ok?) : [] %>
        <% if issues.any? %>
          <% issues.each do |f| %>
            <% seq = box_seq[f.id] %>
            <%# 박스 지정(seq 존재) finding은 <button>으로 렌더 — 키보드 포커스·실행·전역 focus-visible 링 확보
                (states-3, 비교·버전 화면과 상태 표현 일치). 비-박스 카드는 순수 div 유지. 속성은 해시로(Rails 이스케이프·nil 생략). %>
            <% boxed = seq.present?
               f_class = ["rounded-lg border border-line-soft p-3"]
               f_class << "block w-full cursor-pointer text-left hover:border-cooa" if boxed
               f_class << "opacity-0 blur-[2px]" if params[:ran]
               f_data = { "screening-target": "finding" }
               (f_data[:seq] = seq; f_data[:action] = "click->screening#focusFinding") if boxed %>
            <%= content_tag(boxed ? :button : :div, class: f_class.join(" "), type: (boxed ? "button" : nil),
                            style: "border-left:4px solid #{f.decision_meta[:color]}", data: f_data) do %>
              <div class="flex items-center justify-between gap-2">
                <div class="flex min-w-0 items-center gap-2">
                  <% if seq %><%= seq_badge(seq, color: f.decision_meta[:color], size: :md) %><% end %>
                  <span class="shrink-0 rounded bg-tint px-1.5 py-0.5 text-caption text-muted"><%= f.element_label %></span>
                  <span class="truncate text-note font-bold text-ink"><%= f.subject %></span>
                </div>
                <%= decision_pill(f.decision) %>
              </div>
              <%# 근거(판단 사유) %>
              <p class="mt-1.5 text-body text-ink/80"><%= f.issue_description %></p>
              <% if f.recommended_action.present? %><p class="mt-1 text-body text-cooa">→ <%= f.recommended_action %></p><% end %>
              <%# 출처 — 판단 근거의 규제 출처를 명확히 명시(사용자 검증용) %>
              <% if f.citation.present? %>
                <div class="mt-2 flex items-start gap-1.5 rounded-md bg-tint px-2 py-1.5 text-caption">
                  <%= ui_icon "external", size: 12, klass: "mt-0.5 shrink-0 text-muted" %>
                  <span><span class="font-bold text-muted">출처</span> <span class="break-all text-muted"><%= f.citation %></span></span>
                </div>
              <% end %>
              <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-0.5 text-caption text-muted">
                <span>신뢰도 <%= f.confidence %>%</span>
                <% if f.human_review_required? %><span class="font-bold text-ink">· RA 검토 필요</span><% end %>
              </div>
            <% end %>
          <% end %>
        <% elsif @run %>
          <div class="py-12 text-center text-note">
            <span class="inline-flex items-center gap-1.5 text-lead font-bold text-ink"><%= ui_icon "check", size: 16, stroke: 2.4, klass: "text-ok-strong" %>위반·주의 사항 없음</span><br>
            <span class="text-muted">검토 기준을 통과했습니다.</span>
          </div>
        <% else %>
          <div class="py-12 text-center text-note text-ink">아직 스크리닝을 실행하지 않았습니다.<br>아래 <b>‘인허가 스크리닝’</b>을 눌러 실행하세요.</div>
        <% end %>
      </div>

      <%# 버전 리뷰(검토 확인/변경 요청)는 버전 뷰로 이동(리프레임) — 스크리닝 화면은 발견사항만. %>
    </aside>
  </div>

  <%# 하단 액션바 — 국가 미지정이면 실행 차단(거짓 '적합' 방지) %>
  <div class="screening-actionbar flex shrink-0 items-center justify-center gap-3 border-t border-line-soft bg-white px-4 py-3 lg:px-6">
    <% if @product.country.blank? %>
      <span class="flex items-center gap-1.5 text-body font-medium text-warn">
        <%= ui_icon "warn", size: 16 %> 국가가 지정되지 않아 스크리닝을 실행할 수 없습니다 — 드로어에서 국가를 먼저 지정하세요.
      </span>
    <% else %>
      <%# 제출 시 버튼 로딩(스피너 + "스크리닝 중…") — 중복 실행 방지. 리다이렉트(?ran=1)로 새 버튼 렌더 = 리셋.
          결정 A(§9-A): 핑크-보라 그라데이션 제거·primary 버건디 수렴, AI 구분은 spark 아이콘+라벨. %>
      <%= button_to run_screening_component_version_path(@version),
            form: { data: { controller: "submit-loading", action: "submit->submit-loading#onSubmit submit->screening#onRerun", submit_loading_label_value: "스크리닝 중…" } },
            data: { submit_loading_target: "button" },
            class: ui_button_classes(variant: :primary) do %>
        <%= ui_icon "spark", size: 15 %><%= @run ? "인허가 스크리닝 다시 실행" : "인허가 스크리닝" %>
      <% end %>
    <% end %>
  </div>
</div>
