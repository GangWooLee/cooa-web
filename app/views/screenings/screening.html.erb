<% content_for :title, "인허가 스크리닝 · #{@product.code}" %>
<% fboxes = @run ? finding_boxes(@run.screening_findings) : [] %>
<% box_seq = {}; fboxes.each { |b| box_seq[b[:finding_id]] = b[:seq] } %>
<div class="flex h-full flex-col">
  <%# 헤더 + 주의문 %>
  <div class="flex flex-wrap items-center justify-between gap-2 border-b border-line-soft px-5 py-3">
    <div class="text-sm"><%= node_breadcrumb(@product, trailing: "#{@version.component.display_name} #{@version.vlabel.upcase} 인허가 스크리닝") %></div>
    <div class="text-xs text-line">AI의 답변은 완벽하지 않으니 꼭 RA 담당자의 검토를 권합니다.</div>
  </div>

  <div data-controller="screening" data-action="artwork-viewer:focus->screening#onFocus"
       data-screening-just-ran-value="<%= params[:ran].present? %>"
       class="flex min-h-0 flex-1 flex-col lg:flex-row">
    <%# 좌: 아트워크 + finding 박스 (방금 실행 시 스캔 애니메이션) %>
    <div class="relative min-h-0 min-w-0 flex-1 p-3 <%= "screening-scanning" if params[:ran] %>" style="min-height:380px">
      <% if artwork?(@version) %>
        <%= render "shared/artwork_viewer", image_src: artwork_src(@version), boxes: fboxes, zoom: false %>
        <%# 스캔 빔 오버레이 — 방금 실행 시 JS가 표시 후 애니메이션 %>
        <div data-screening-target="scanner" class="pointer-events-none absolute inset-3 z-20 hidden overflow-hidden rounded-xl">
          <div class="scan-beam"></div>
        </div>
      <% else %>
        <div class="flex h-full items-center justify-center rounded-xl border border-line bg-tint-2 text-line">아트워크 이미지 없음 · <%= @version.component.display_name %> <%= @version.vlabel.upcase %></div>
      <% end %>
    </div>

    <%# 우: 결과 패널 %>
    <aside class="flex w-full shrink-0 flex-col border-t border-line bg-white lg:w-[400px] lg:border-l lg:border-t-0">
      <div class="border-b border-line-soft p-3">
        <h3 class="text-base font-bold text-ink">스크리닝 결과</h3>
        <% if @run %>
          <% counts = @run.screening_findings.group(:decision).count %>
          <div class="mt-2 flex flex-wrap items-center gap-1.5">
            <% Decidable::DECISIONS.each do |key, meta| %>
              <% next if key == "ok" %>
              <% n = counts[key] || 0 %>
              <% on = n.positive? %>
              <span class="inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1 text-[13px] font-bold"
                    style="color:<%= on ? meta[:color] : "#9aa0a6" %>;background:<%= on ? meta[:bg] : "#f1f1f1" %>">
                <%= meta[:label] %>
                <span class="flex h-[18px] min-w-[18px] items-center justify-center rounded px-1 text-xs text-white" style="background:<%= on ? meta[:color] : "#b9bcc2" %>"><%= n %></span>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="min-h-0 flex-1 space-y-2 overflow-auto p-3">
        <%# 목적=위반 탐지 → '적합'(ok)은 노출하지 않음 %>
        <% issues = @run ? @run.screening_findings.reject(&:decision_ok?) : [] %>
        <% if issues.any? %>
          <% issues.each do |f| %>
            <% seq = box_seq[f.id] %>
            <div data-screening-target="finding" <%= seq ? "data-seq=\"#{seq}\"".html_safe : "" %>
                 class="rounded-lg border border-line-soft p-3 <%= "cursor-pointer hover:border-cooa" if seq %> <%= "opacity-0 blur-[2px]" if params[:ran] %>"
                 style="border-left:4px solid <%= f.decision_meta[:color] %>"
                 <%= seq ? 'data-action="click->screening#focusFinding"'.html_safe : "" %>>
              <div class="flex items-center justify-between gap-2">
                <div class="flex min-w-0 items-center gap-2">
                  <% if seq %><span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[11px] font-bold text-white" style="background:<%= f.decision_meta[:color] %>"><%= seq %></span><% end %>
                  <span class="shrink-0 rounded bg-tint px-1.5 py-0.5 text-[11px] text-ink/60"><%= f.element_label %></span>
                  <span class="truncate text-sm font-bold text-ink"><%= f.subject %></span>
                </div>
                <%= decision_pill(f.decision) %>
              </div>
              <%# 근거(판단 사유) %>
              <p class="mt-1.5 text-[13px] text-ink/80"><%= f.issue_description %></p>
              <% if f.recommended_action.present? %><p class="mt-1 text-[13px] text-cooa">→ <%= f.recommended_action %></p><% end %>
              <%# 출처 — 판단 근거의 규제 출처를 명확히 명시(사용자 검증용) %>
              <% if f.citation.present? %>
                <div class="mt-2 flex items-start gap-1.5 rounded-md bg-tint px-2 py-1.5 text-[11px]">
                  <%= ui_icon "external", size: 12, klass: "mt-0.5 shrink-0 text-line" %>
                  <span><span class="font-bold text-line">출처</span> <span class="break-all text-ink/70"><%= f.citation %></span></span>
                </div>
              <% end %>
              <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-0.5 text-[11px] text-line">
                <span>신뢰도 <%= f.confidence %>%</span>
                <% if f.human_review_required? %><span class="font-bold text-warn">· RA 검토 필요</span><% end %>
              </div>
            </div>
          <% end %>
        <% elsif @run %>
          <div class="py-12 text-center text-sm">
            <span class="text-[15px] font-bold" style="color:#5f8f2e">✓ 위반·주의 사항 없음</span><br>
            <span class="text-line">검토 기준을 통과했습니다.</span>
          </div>
        <% else %>
          <div class="py-12 text-center text-sm text-line">아직 스크리닝을 실행하지 않았습니다.<br>아래 <b>‘인허가 스크리닝’</b>을 눌러 실행하세요.</div>
        <% end %>
      </div>

      <% if @run&.status == "approved" %>
        <div class="border-t border-line-soft p-3 text-center text-[13px] font-bold" style="color:#5f8f2e;background:#eef6e3">✓ <%= @run.approved_by&.name %> (RA) 승인 완료 · <%= @run.approved_at&.strftime("%Y.%m.%d %H:%M") %></div>
      <% end %>
    </aside>
  </div>

  <%# 하단 액션바 %>
  <div class="flex items-center justify-center gap-3 border-t border-line-soft bg-white px-6 py-3">
    <%= button_to (@run ? "인허가 스크리닝 다시 실행" : "인허가 스크리닝"), run_screening_component_version_path(@version),
          class: "rounded-lg px-6 py-2.5 text-[15px] font-bold text-ink", style: "background-image:linear-gradient(to right,#fdd5d4,#e6caff)" %>
    <% if @run %>
      <%= button_to "승인하기", approve_screening_component_version_path(@version),
            class: "bg-cooa-gradient rounded-lg px-6 py-2.5 text-[15px] font-bold text-white",
            form: { data: { turbo_confirm: "이 버전을 RA 승인 처리할까요?" } } %>
    <% end %>
  </div>
</div>
