<% content_for :title, "인허가 스크리닝 · #{@product.code}" %>
<div class="flex h-full flex-col bg-tint">
  <%# 헤더 + 주의문 %>
  <div class="flex flex-wrap items-center justify-between gap-2 px-6 pt-4">
    <div class="text-[13px]"><%= node_breadcrumb(@product, trailing: "#{@version.component.type_label} #{@version.vlabel.upcase}") %></div>
    <div class="text-[13px] text-line">AI의 답변은 완벽하지 않으니 꼭 RA 담당자의 검토를 권합니다.</div>
  </div>

  <div class="flex min-h-0 flex-1 gap-4 px-6 py-4">
    <%# 좌: 아트워크 %>
    <div class="flex min-w-0 flex-1 items-center justify-center rounded-2xl border border-line bg-white p-4 shadow-sm">
      <% if @version.image_name.present? %>
        <%= image_tag @version.image_name, class: "max-h-full max-w-full rounded-lg object-contain", alt: "아트워크" %>
      <% else %>
        <div class="text-center text-line"><%= ui_icon "layers", size: 40, klass: "mx-auto mb-2" %>아트워크 미리보기 없음<br><span class="text-[12px]"><%= @version.component.type_label %> <%= @version.vlabel.upcase %></span></div>
      <% end %>
    </div>

    <%# 우: 결과 패널 %>
    <div class="flex w-[440px] shrink-0 flex-col rounded-2xl border border-line bg-white shadow-sm">
      <div class="border-b border-line-soft p-4">
        <div class="flex items-center justify-between">
          <h2 class="text-[16px] font-bold text-ink">인허가 스크리닝 결과</h2>
          <span class="rounded-full bg-tint px-2 py-0.5 text-[12px] text-ink/70"><%= @country_label %></span>
        </div>
        <% if @run %>
          <div class="mt-2 flex items-center gap-2">
            <%= decision_pill(@run.decision) %>
            <span class="text-[12px] text-ink/70"><%= @run.summary %></span>
          </div>
        <% end %>
      </div>

      <div class="min-h-0 flex-1 space-y-2 overflow-auto p-4">
        <% if @run && @run.screening_findings.any? %>
          <%= render partial: "screenings/finding", collection: @run.screening_findings, as: :finding %>
        <% else %>
          <div class="py-12 text-center text-[14px] text-line">
            아직 스크리닝을 실행하지 않았습니다.<br>아래 <b>‘인허가 스크리닝’</b>을 눌러 실행하세요.
          </div>
        <% end %>
      </div>

      <% if @run&.status == "approved" %>
        <div class="border-t border-line-soft p-3 text-center text-[13px] font-bold" style="color:#5f8f2e;background:#eef6e3">
          ✓ <%= @run.approved_by&.name %> (RA) 승인 완료 · <%= @run.approved_at&.strftime("%Y.%m.%d %H:%M") %>
        </div>
      <% end %>
    </div>
  </div>

  <%# 하단 액션바 %>
  <div class="flex items-center justify-center gap-3 border-t border-line-soft bg-white px-6 py-3">
    <%= button_to run_screening_component_version_path(@version),
          class: "rounded-lg px-6 py-2.5 text-[15px] font-bold text-ink",
          style: "background-image:linear-gradient(to right,#fdd5d4,#e6caff)" do %>
      <%= @run ? "인허가 스크리닝 다시 실행" : "인허가 스크리닝" %>
    <% end %>
    <% if @run %>
      <%= button_to approve_screening_component_version_path(@version),
            class: "bg-cooa-gradient rounded-lg px-6 py-2.5 text-[15px] font-bold text-white",
            form: { data: { turbo_confirm: "이 버전을 RA 승인 처리할까요?" } } do %>
        승인하기
      <% end %>
    <% end %>
  </div>
</div>
