<% m = finding.decision_meta %>
<div class="rounded-lg border border-line-soft p-3" style="border-left:4px solid <%= m[:color] %>">
  <div class="flex items-center justify-between gap-2">
    <div class="flex min-w-0 items-center gap-2">
      <span class="shrink-0 rounded bg-tint px-1.5 py-0.5 text-[11px] text-ink/60"><%= finding.element_label %></span>
      <span class="truncate text-[14px] font-bold text-ink"><%= finding.subject %></span>
    </div>
    <%= decision_pill(finding.decision) %>
  </div>
  <p class="mt-1.5 text-[13px] text-ink/80"><%= finding.issue_description %></p>
  <% if finding.recommended_action.present? %>
    <p class="mt-1 text-[13px] text-cooa">→ <%= finding.recommended_action %></p>
  <% end %>
  <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-0.5 text-[11px] text-line">
    <% if finding.citation.present? %>
      <span class="inline-flex items-center gap-1"><%= ui_icon "external", size: 12 %><%= finding.citation %></span>
    <% end %>
    <span>신뢰도 <%= finding.confidence %>%</span>
    <% if finding.human_review_required? %><span class="font-bold text-warn">· RA 검토 필요</span><% end %>
  </div>
</div>
