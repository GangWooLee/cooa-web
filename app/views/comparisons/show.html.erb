<% content_for :title, "버전 비교 · #{@product.code}" %>
<div class="flex h-full flex-col" data-controller="comparison"
     data-action="artwork-viewer:focus->comparison#onFocus artwork-viewer:draw->comparison#onDraw">
  <%# 상단: 브레드크럼 + 버전 페어 선택기 (가치 라벨 없음) + 우패널 접기 %>
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-line-soft px-6 py-3">
    <div class="text-note"><%= node_breadcrumb(@product, trailing: "#{@component.display_name} 버전 비교") %></div>
    <div class="flex items-center gap-2">
      <div data-controller="version-picker" class="flex items-center gap-2 text-note">
        <span class="text-meta text-muted">기준</span>
        <select data-role="from" data-action="change->version-picker#go" class="rounded-md border border-line-soft bg-white px-2 py-1">
          <% @versions.each do |v| %><option value="<%= v.id %>" <%= "selected" if v.id == @from.id %>><%= v.vlabel %></option><% end %>
        </select>
        <span class="text-muted">→</span>
        <span class="text-meta text-muted">검토</span>
        <select data-role="to" data-action="change->version-picker#go" class="rounded-md border border-line-soft bg-white px-2 py-1">
          <% @versions.each do |v| %><option value="<%= v.id %>" <%= "selected" if v.id == @to.id %>><%= v.vlabel %></option><% end %>
        </select>
      </div>
      <%# 우패널(피드백) 접기 — lg+에서만(그 이하는 아래로 쌓여 접기 불필요). aria-pressed=접힘 상태. %>
      <button type="button" data-action="comparison#toggleAside" aria-pressed="false"
              title="피드백 패널 접기/펼치기" aria-label="피드백 패널 접기/펼치기"
              class="hidden h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-line-soft bg-white text-muted transition hover:border-cooa hover:text-cooa aria-pressed:border-cooa aria-pressed:bg-accent aria-pressed:text-cooa lg:inline-flex">
        <%= ui_icon "panel-left", size: 16, klass: "scale-x-[-1]" %>
      </button>
    </div>
  </div>

  <%# 본문: 뷰어 + 우측 패널 %>
  <div class="flex min-h-0 flex-1 flex-col lg:flex-row">
    <%# 좌: 검토(현재) 버전 아트워크 + 이전 버전 피드백 박스 %>
    <div class="min-h-0 min-w-0 flex-1 p-3" style="min-height:380px">
      <% if artwork?(@from) && artwork?(@to) %>
        <% anns = annotation_boxes(@from.annotations.ordered) %>
        <%= render "shared/artwork_viewer",
              worker_src: asset_path("pdfjs.worker.min.js"),
              panes: [
                { image_src: artwork_src(@from), thumb_src: artwork_thumb_src(@from), is_pdf: @from.artwork_pdf?, label: @from.vlabel, boxes: anns },
                { image_src: artwork_src(@to),   thumb_src: artwork_thumb_src(@to),   is_pdf: @to.artwork_pdf?,   label: @to.vlabel,   boxes: anns }
              ],
              drawable: true, zoom: true %><%# 줌 활성(세 아트워크 뷰 일관) · autofocus 제거: 초기 무선택(전 박스 선명), 클릭 토글로 포커스 %>
      <% else %>
        <div class="flex h-full items-center justify-center rounded-xl border border-line bg-tint-2 text-muted">이 구성요소는 아트워크 이미지가 없습니다.</div>
      <% end %>
    </div>

    <%# 우: 피드백 목록 / 상세 / 새 박스 %>
    <aside data-comparison-target="aside" class="flex w-full shrink-0 flex-col border-t border-line bg-white lg:w-[360px] lg:border-l lg:border-t-0">
      <%# 목록 %>
      <div data-comparison-target="list" class="flex min-h-0 flex-1 flex-col">
        <div class="border-b border-line-soft p-3">
          <h3 class="text-section font-bold text-ink">피드백 <span class="text-muted">(<%= @annotations.size %>)</span></h3>
          <p class="text-meta text-muted"><%= @from.vlabel %>에서 제기 · <%= @to.vlabel %> 반영 검토 · <b class="text-ink"><%= @annotations.count(&:resolved?) %> 반영</b> / <b class="text-cooa"><%= @annotations.count(&:open?) %> 미반영</b></p>
        </div>
        <div class="min-h-0 flex-1 space-y-2 overflow-auto p-3">
          <% @annotations.each do |a| %>
            <button type="button" data-seq="<%= a.seq %>" data-action="comparison#focusFromList"
                    class="block w-full rounded-lg border border-line-soft p-2.5 text-left transition hover:border-cooa">
              <div class="flex items-center justify-between">
                <span class="flex items-center gap-2">
                  <span class="flex h-5 w-5 items-center justify-center rounded-full border-2 bg-white text-caption font-bold text-ink" style="border-color:<%= a.box_color %>"><%= a.seq %></span>
                  <span class="rounded bg-tint px-1.5 py-0.5 text-caption text-muted"><%= a.category %></span>
                </span>
                <%= annotation_status_pill(a) %>
              </div>
              <p class="mt-1 line-clamp-2 text-meta text-ink/80"><%= a.comments.first&.body %></p>
            </button>
          <% end %>
        </div>
      </div>

      <%# 상세 패널 (어노테이션별, 기본 숨김) %>
      <% @annotations.each do |a| %>
        <div data-comparison-target="detail" data-seq="<%= a.seq %>" class="hidden min-h-0 flex-1 flex-col">
          <div class="flex items-center gap-2 border-b border-line-soft p-3">
            <button type="button" data-action="comparison#backToList" class="text-note text-muted hover:text-cooa">← 목록</button>
            <span class="flex h-5 w-5 items-center justify-center rounded-full border-2 bg-white text-caption font-bold text-ink" style="border-color:<%= a.box_color %>"><%= a.seq %></span>
            <span class="rounded bg-tint px-1.5 py-0.5 text-caption text-muted"><%= a.category %></span>
            <%= annotation_status_pill(a, extra: "ml-auto") %>
          </div>
          <div class="min-h-0 flex-1 overflow-auto p-3">
            <p class="mb-2 text-caption text-muted">← 좌(이전)·우(현재) 캔버스에서 이 영역이 확대됩니다.</p>
            <% if a.before_text.present? %>
              <div class="mt-2 rounded-lg bg-tint px-2 py-1.5 text-meta">
                <span class="text-muted line-through"><%= a.before_text %></span><span class="px-1 text-muted">→</span><span class="font-bold text-ink"><%= a.after_text %></span>
              </div>
            <% end %>
            <%# 코멘트 스레드 %>
            <div class="mt-3 space-y-2">
              <% a.comments.each do |c| %>
                <div class="rounded-lg border border-line-soft p-2">
                  <div class="flex items-center gap-1.5"><%= avatar(c.author, size: 20) %><span class="text-meta font-bold text-ink"><%= c.author.name %></span><span class="text-caption text-muted"><%= c.author.role_short %></span></div>
                  <p class="mt-1 text-meta text-ink/85"><%= c.body %></p>
                  <% if c.attachment_name.present? %><div class="mt-1 inline-flex items-center gap-1 rounded bg-tint text-muted px-1.5 py-0.5 text-caption"><%= ui_icon "external", size: 11 %><%= c.attachment_name %></div><% end %>
                </div>
              <% end %>
            </div>
            <%= form_with url: annotation_comments_path(a), class: "mt-2 flex gap-1" do %>
              <%= text_field_tag :body, nil, placeholder: "코멘트 추가", class: "min-w-0 flex-1 rounded border border-line-soft px-2 py-1 text-meta" %>
              <%= ui_button "등록", size: :sm, type: "submit" %>
            <% end %>
          </div>
          <%# 반영 확인 %>
          <div class="border-t border-line-soft p-3">
            <% if a.resolved? %>
              <div class="flex items-center justify-between text-meta">
                <span class="inline-flex items-center gap-1 font-bold text-ink"><%= ui_icon "check", size: 13, stroke: 2.4, klass: "text-ok-strong" %><%= a.resolved_in_version&.vlabel %>에서 반영 확인</span>
                <%= button_to "다시 열기", reopen_annotation_path(a), method: :patch, class: ui_button_classes(variant: :ghost, size: :sm) %>
              </div>
            <% else %>
              <%= button_to resolve_annotation_path(a, resolved_in_version_id: @to.id), method: :patch,
                    class: "inline-flex w-full cursor-pointer items-center justify-center gap-1.5 rounded-lg border border-ok-strong bg-ok-soft py-2 text-body font-bold text-ink transition hover:bg-white" do %><%= ui_icon "check", size: 15, stroke: 2.4, klass: "text-ok-strong" %><%= @to.vlabel %>에서 반영됨으로 표시<% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# 새 피드백 (Shift+드래그 시 표시) %>
      <div data-comparison-target="newForm" class="hidden flex-1 flex-col border-t border-line-soft p-3">
        <div class="mb-2 flex items-center justify-between">
          <h4 class="text-note font-bold text-ink">새 피드백 (<%= @to.vlabel %>)</h4>
          <button type="button" data-action="comparison#backToList" class="text-meta text-muted">취소</button>
        </div>
        <%= form_with url: component_version_annotations_path(@to), class: "space-y-2" do %>
          <%= hidden_field_tag :box_x, nil, data: { comparison_target: "newX" } %>
          <%= hidden_field_tag :box_y, nil, data: { comparison_target: "newY" } %>
          <%= hidden_field_tag :box_w, nil, data: { comparison_target: "newW" } %>
          <%= hidden_field_tag :box_h, nil, data: { comparison_target: "newH" } %>
          <select name="category" class="w-full rounded border border-line-soft px-2 py-1 text-note">
            <option>오탈자</option><option>인허가</option><option>디자인</option><option>기타</option>
          </select>
          <%= text_area_tag :body, nil, rows: 3, placeholder: "수정 요청 내용", class: "w-full rounded border border-line-soft px-2 py-1 text-note" %>
          <%= ui_button "피드백 추가", type: "submit", class: "w-full" %>
        <% end %>
      </div>
    </aside>
  </div>
</div>
