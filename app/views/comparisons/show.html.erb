<% content_for :title, "버전 비교 · #{@product.code}" %>
<div class="flex h-full flex-col" data-controller="comparison"
     data-action="artwork-viewer:focus->comparison#onFocus artwork-viewer:draw->comparison#onDraw">
  <%# 상단: 브레드크럼 + 버전 페어 선택기 (가치 라벨 없음) + 우패널 접기 %>
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-line-soft px-6 py-3">
    <%# 비교는 기준 버전(@from)으로 올라가는 링크로 분해 — 현재 세그먼트는 '버전 비교'만 text-ink(ia-nav-3). %>
    <div class="text-note"><%= node_breadcrumb(@product,
          trailing_link: [ "#{@component.display_name} #{@from.vlabel}", component_version_path(@from) ],
          trailing: "버전 비교") %></div>
    <div class="flex items-center gap-2">
      <div data-controller="version-picker" class="flex items-center gap-2 text-note">
        <span class="text-meta text-muted">기준</span>
        <select data-role="from" data-action="change->version-picker#go" class="<%= ui_select_classes(extra: "py-1") %>">
          <% @versions.each do |v| %><option value="<%= v.id %>" <%= "selected" if v.id == @from.id %>><%= v.vlabel %></option><% end %>
        </select>
        <span class="text-muted">→</span>
        <span class="text-meta text-muted">검토</span>
        <select data-role="to" data-action="change->version-picker#go" class="<%= ui_select_classes(extra: "py-1") %>">
          <% @versions.each do |v| %><option value="<%= v.id %>" <%= "selected" if v.id == @to.id %>><%= v.vlabel %></option><% end %>
        </select>
      </div>
      <%# 우패널(피드백) 접기 — lg+에서만(그 이하는 아래로 쌓여 접기 불필요). aria-pressed=접힘 상태. %>
      <button type="button" data-action="comparison#toggleAside" aria-pressed="false"
              title="피드백 패널 접기/펼치기" aria-label="피드백 패널 접기/펼치기"
              class="hidden h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-line-soft bg-white text-muted transition hover:border-cooa hover:text-cooa aria-pressed:border-cooa aria-pressed:bg-accent aria-pressed:text-cooa lg:inline-flex">
        <%= ui_icon "panel-left", size: 16, klass: "scale-x-[-1]" %>
      </button>
    </div>
  </div>

  <%# 본문: 뷰어 + 우측 패널 %>
  <div class="flex min-h-0 flex-1 flex-col lg:flex-row">
    <%# 좌: 검토(현재) 버전 아트워크 + 이전 버전 피드백 박스 %>
    <div class="min-h-0 min-w-0 flex-1 p-3" style="min-height:380px">
      <% if artwork?(@from) && artwork?(@to) %>
        <% anns = annotation_boxes(@from.annotations.ordered) %>
        <%= render "shared/artwork_viewer",
              worker_src: asset_path("pdfjs.worker.min.js"),
              panes: [
                { image_src: artwork_src(@from), thumb_src: artwork_thumb_src(@from), is_pdf: @from.artwork_pdf?, label: @from.vlabel, boxes: anns },
                { image_src: artwork_src(@to),   thumb_src: artwork_thumb_src(@to),   is_pdf: @to.artwork_pdf?,   label: @to.vlabel,   boxes: anns }
              ],
              drawable: true, zoom: true %><%# 줌 활성(세 아트워크 뷰 일관) · autofocus 제거: 초기 무선택(전 박스 선명), 클릭 토글로 포커스 %>
      <% else %>
        <div class="flex h-full items-center justify-center rounded-xl border border-line bg-tint-2 text-muted">이 구성요소는 아트워크 이미지가 없습니다.</div>
      <% end %>
    </div>

    <%# 우: 피드백 목록 / 상세 / 새 박스 %>
    <aside data-comparison-target="aside" class="flex w-full shrink-0 flex-col border-t border-line bg-white lg:w-[380px] lg:border-l lg:border-t-0">
      <%# 목록 + 상세 — shared/_feedback_panel(M4 공용). 비교 뷰: 제기/반영 요약 헤더 · before→after diff ·
          첨부명 표시 · resolve 게이트 없음(리뷰 컨텍스트는 @to 기준). 새 피드백 폼은 화면 고유(아래). %>
      <% subtitle = capture do %><%= @from.vlabel %>에서 제기 · <%= @to.vlabel %> 반영 검토 · <b class="text-ink"><%= @annotations.count(&:resolved?) %> 반영</b> / <b class="text-cooa"><%= @annotations.count(&:open?) %> 미반영</b><% end %>
      <%= render "shared/feedback_panel", controller: "comparison", annotations: @annotations,
            list_subtitle: subtitle, empty_text: "이 구간에서 제기된 피드백이 없습니다.",
            focus_hint: "← 좌(이전)·우(현재) 캔버스에서 이 영역이 확대됩니다.", thread_class: "mt-3",
            show_diff: true, show_attachment: true, resolve_gated: false,
            resolve_version: @to, resolve_label: "#{@to.vlabel}에서 반영됨으로 표시", resolved_fallback: nil %>

      <%# 새 피드백 (Shift+드래그 시 표시) %>
      <div data-comparison-target="newForm" class="hidden flex-1 flex-col border-t border-line-soft p-3">
        <div class="mb-2 flex items-center justify-between">
          <h4 class="text-note font-bold text-ink">새 피드백 (<%= @to.vlabel %>)</h4>
          <button type="button" data-action="comparison#backToList" class="text-meta text-muted">취소</button>
        </div>
        <%= form_with url: component_version_annotations_path(@to), class: "space-y-2" do %>
          <%= hidden_field_tag :box_x, nil, data: { comparison_target: "newX" } %>
          <%= hidden_field_tag :box_y, nil, data: { comparison_target: "newY" } %>
          <%= hidden_field_tag :box_w, nil, data: { comparison_target: "newW" } %>
          <%= hidden_field_tag :box_h, nil, data: { comparison_target: "newH" } %>
          <select name="category" class="w-full rounded border border-line-soft px-2 py-1 text-note">
            <option>오탈자</option><option>인허가</option><option>디자인</option><option>기타</option>
          </select>
          <%= text_area_tag :body, nil, rows: 3, placeholder: "수정 요청 내용", class: "w-full rounded border border-line-soft px-2 py-1 text-note" %>
          <%= ui_button "피드백 추가", type: "submit", class: "w-full" %>
        <% end %>
      </div>
    </aside>
  </div>
</div>
