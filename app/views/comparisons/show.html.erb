<% content_for :title, "버전 비교 · #{@product.code}" %>
<div class="flex h-full">
  <%# ── 좌: 아트워크 2단 + 변경점 범례 ── %>
  <section class="flex min-w-0 flex-1 flex-col bg-tint p-6">
    <div class="mb-3 text-[13px]"><%= node_breadcrumb(@product, trailing: "#{@component.type_label} 버전 비교") %></div>

    <div class="flex min-h-0 flex-1 gap-5">
      <%# 현 위치 (from) — 마커 표시 %>
      <div class="flex min-w-0 flex-1 flex-col">
        <div class="mb-1.5 flex items-center gap-2">
          <%= version_chip(@from.vlabel.upcase, size: 26) %>
          <span class="text-[14px] font-bold text-ink"><%= @from.label %></span>
          <span class="rounded bg-cooa px-1.5 py-0.5 text-[11px] font-bold text-white">현 위치</span>
        </div>
        <div class="relative min-h-0 flex-1 overflow-hidden rounded-2xl border border-line bg-white shadow-sm">
          <% if @from.image_name.present? %>
            <%= image_tag @from.image_name, class: "h-full w-full object-contain p-3" %>
          <% end %>
          <% @diffs.each do |d| %>
            <span class="absolute flex h-6 w-6 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-md bg-cooa text-[12px] font-bold text-white ring-2 ring-white"
                  style="left:<%= d.marker_x %>%;top:<%= d.marker_y %>%"><%= d.marker_label %></span>
          <% end %>
        </div>
      </div>

      <%# 비교 대상 (to) %>
      <div class="flex min-w-0 flex-1 flex-col">
        <div class="mb-1.5 flex items-center gap-2">
          <%= version_chip(@to.vlabel.upcase, size: 26) %>
          <span class="text-[14px] font-bold text-ink"><%= @to.label %></span>
          <span class="rounded bg-line px-1.5 py-0.5 text-[11px] font-bold text-white">비교 대상</span>
        </div>
        <div class="relative min-h-0 flex-1 overflow-hidden rounded-2xl border-2 bg-white shadow-sm" style="border-color:#fc7976">
          <% if @to.image_name.present? %>
            <%= image_tag @to.image_name, class: "h-full w-full object-contain p-3" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# 변경점 범례 %>
    <% if @diffs.any? %>
      <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-2 rounded-2xl border border-line bg-white p-3 shadow-sm">
        <span class="text-[13px] font-bold text-ink">변경점</span>
        <% @diffs.each do |d| %>
          <div class="flex items-center gap-2">
            <span class="flex h-5 w-5 items-center justify-center rounded bg-cooa text-[11px] font-bold text-white"><%= d.marker_label %></span>
            <div class="text-[13px]">
              <span class="text-line line-through"><%= d.before_text %></span>
              <span class="px-1 text-line">→</span>
              <span class="font-bold text-ink"><%= d.after_text %></span>
              <span class="ml-1 rounded bg-tint px-1 py-0.5 text-[10px] text-ink/60"><%= d.category %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <%# ── 우: 피드백 아카이빙 + AI 수정 여부 체크 ── %>
  <aside class="flex w-[336px] shrink-0 flex-col border-l border-line bg-white">
    <div class="flex min-h-0 flex-1 flex-col border-b border-line-soft">
      <div class="flex items-center gap-2 p-3">
        <%= version_chip(@from.vlabel.upcase, size: 22) %>
        <h3 class="text-[15px] font-bold text-ink">피드백 아카이빙</h3>
      </div>
      <div id="feedback-list" class="min-h-0 flex-1 space-y-2 overflow-auto px-3 pb-2">
        <%= render partial: "feedbacks/feedback", collection: @feedbacks, as: :feedback %>
      </div>
      <%= render "comparisons/feedback_form", version: @from %>
    </div>

    <div class="p-3">
      <div class="mb-2 flex items-center gap-2">
        <%= ui_icon "spark", size: 18, klass: "text-cooa" %>
        <h3 class="text-[15px] font-bold text-ink">AI 수정 여부 체크</h3>
      </div>
      <% if flash[:notice] %>
        <div class="mb-2 rounded-lg bg-accent px-3 py-1.5 text-[12px] font-bold text-cooa"><%= flash[:notice] %></div>
      <% end %>
      <div class="space-y-1.5">
        <% @check_items.each do |ci| %>
          <% m = ci.status_meta %>
          <div class="flex items-center gap-2 rounded-full border px-3 py-1.5 text-[13px]"
               style="border-color:<%= m[:color] %>55;color:<%= m[:color] %>">
            <%= ui_icon m[:icon], size: 16, stroke: 2.3 %>
            <span class="text-ink"><%= ci.label %></span>
          </div>
        <% end %>
      </div>
      <%= button_to "다시 체크하기", recheck_comparison_path(from_id: @from.id, to_id: @to.id),
            class: "mt-3 w-full cursor-pointer rounded-lg py-2 text-[14px] font-bold text-ink",
            style: "background-image:linear-gradient(to right,#fdd5d4,#e6caff)" %>
    </div>
  </aside>
</div>
