<div id="feedback-form" class="border-t border-line-soft p-3">
  <%= form_with url: component_version_feedbacks_path(version), class: "flex flex-col gap-2" do %>
    <%= text_area_tag :body, nil, rows: 2, placeholder: "수정 요청사항을 입력하세요.",
          class: "w-full resize-none rounded-lg border border-line-soft px-2 py-1.5 text-[13px] text-ink outline-none focus:border-cooa" %>
    <div class="flex justify-end gap-2">
      <button type="reset" class="rounded bg-tint px-3 py-1 text-[12px] text-ink">취소</button>
      <%= submit_tag "추가", class: "cursor-pointer rounded bg-cooa px-3 py-1 text-[12px] font-bold text-white" %>
    </div>
  <% end %>
</div>
