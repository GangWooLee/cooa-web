<%# 공통 좌측 사이드바: 사용자 · 아트워크 찾기(트리 필터) · 제품 디렉터리 트리(노션형) %>
<aside id="app-sidebar" class="hidden w-[281px] min-w-0 shrink-0 flex-col border-r border-line bg-white lg:flex">
  <%# 사용자 (접기/펼치기는 상단바 토글로 통일) %>
  <div class="flex min-w-0 items-center gap-2 px-3 pb-3 pt-4">
    <%= ui_icon "user", size: 24, klass: "shrink-0 text-ink" %>
    <span class="truncate text-[18px] font-bold text-ink"><%= current_user&.name %></span>
    <span class="ml-auto flex shrink-0 items-center gap-1.5">
      <span class="rounded bg-tint px-1.5 py-0.5 text-[10px] text-line">데모</span>
      <%= button_to "로그아웃", session_path, method: :delete, form: { class: "inline" },
            class: "rounded px-1.5 py-0.5 text-[10px] text-line transition hover:bg-tint hover:text-cooa" %>
    </span>
  </div>

  <%# 내게 요청된 리뷰 수신함(내가 지정 리뷰어인 pending 요청) %>
  <%= link_to reviews_path, data: { turbo: false },
        class: "mx-2 mb-1 flex items-center gap-2 rounded-lg px-3 py-2 text-[13px] font-medium text-ink transition hover:bg-tint #{'bg-tint' if current_page?(reviews_path)}" do %>
    <%= ui_icon "bell", size: 16, klass: "text-line" %>
    <span>내 리뷰 인박스</span>
    <%# 배지 정책(REF L493): pending(bg-cooa)은 내 Segment A 전체로 불변. overdue(bg-warn)는 그 부분집합을
        별도 병기 — 내 배정분만(bounded·개인 액션어블). Segment B는 미배지(인박스 행 강조로만). %>
    <% if pending_review_count.positive? %>
      <span class="ml-auto flex items-center gap-1">
        <% if overdue_review_count.positive? %>
          <span title="마감 초과 <%= overdue_review_count %>건" class="flex h-5 min-w-[20px] items-center justify-center rounded-full bg-warn px-1.5 text-[11px] font-bold text-white"><%= overdue_review_count %></span>
        <% end %>
        <span class="flex h-5 min-w-[20px] items-center justify-center rounded-full bg-cooa px-1.5 text-[11px] font-bold text-white"><%= pending_review_count %></span>
      </span>
    <% end %>
  <% end %>

  <%# 멤버(조직 로스터·초대, Phase 3) — 로스터 열람권자에게만 노출. tenant-wide 읽기권자 OR scoped
      brand_admin(자기 브랜드) — scoped admin은 조직 verb를 통과 못 하므로 can_view_members?로 판정(T3). %>
  <% if can_view_members? %>
    <%= link_to members_path, data: { turbo: false },
          class: "mx-2 mb-1 flex items-center gap-2 rounded-lg px-3 py-2 text-[13px] font-medium text-ink transition hover:bg-tint #{'bg-tint' if current_page?(members_path)}" do %>
      <%= ui_icon "user", size: 16, klass: "text-line" %>
      <span>멤버</span>
    <% end %>
  <% end %>

  <%# 제품 디렉터리 트리 + 아트워크 찾기(클라이언트 필터) %>
  <nav class="mt-1 flex min-w-0 flex-1 flex-col overflow-hidden px-2 pb-6" data-controller="tree-filter tree-ctx">
    <%# 검색(트리 필터 — 서버 왕복 0). 매치 카운트 + ✕/Esc 클리어는 tree_filter_controller가 토글. %>
    <div class="px-[15px] pb-3">
      <div class="relative">
        <input data-tree-filter-target="input" data-action="input->tree-filter#filter keydown->tree-filter#keydown"
               placeholder="아트워크 찾기 (품목코드, 품목명)" class="w-full rounded-lg bg-tint px-3 py-2 pr-16 text-[15px] outline-none">
        <div class="pointer-events-none absolute inset-y-0 right-2 flex items-center gap-1">
          <span data-tree-filter-target="count" class="hidden rounded bg-tint-2 px-1.5 py-0.5 text-[11px] font-medium text-line"></span>
          <button type="button" data-tree-filter-target="clear" data-action="tree-filter#clear" title="검색 지우기" aria-label="검색 지우기"
                  class="pointer-events-auto hidden rounded p-0.5 text-line transition hover:text-cooa"><%= ui_icon "x", size: 14 %></button>
        </div>
      </div>
    </div>

    <div class="flex-1 overflow-auto">
      <div class="mb-1 flex items-center justify-between px-2">
        <span class="text-[12px] font-bold text-line">제품</span>
        <%# origin=side → create가 rename_side로 리다이렉트(사이드바에서 인라인 명명) %>
        <%= button_to products_path, params: { product: { kind: "folder" }, origin: "side" }, title: "새 폴더",
              form: { class: "inline" },
              class: "rounded p-0.5 text-line transition hover:bg-tint hover:text-cooa" do %><%= ui_icon "plus", size: 14 %><% end %>
      </div>
      <% active_ids = (@product&.self_and_ancestors&.map(&:id) || []) %>
      <%# rename 대상의 조상 <details>를 열어 인라인 입력칸이 보이게 %>
      <% if (rid = params[:rename_side]).present? && (rnode = Product.find_by(id: rid)) %>
        <% active_ids |= rnode.self_and_ancestors.map(&:id) %>
      <% end %>
      <%# 브레드크럼 폴더 클릭(focus) → 해당 폴더 + 조상 펼침 %>
      <% if (fid = params[:focus]).present? && (fnode = Product.find_by(id: fid)) %>
        <% active_ids |= fnode.self_and_ancestors.map(&:id) %>
      <% end %>
      <% (@tree_roots || []).each do |node| %>
        <%= render "shared/tree_node", node: node, active_ids: active_ids, current_id: @product&.id, root: true %>
      <% end %>
      <%# 검색 무매치 시 tree_filter가 노출(그 외엔 hidden). %>
      <p data-tree-filter-target="empty" class="hidden px-3 py-6 text-center text-[13px] text-line">일치하는 항목 없음</p>
    </div>

    <%= render "shared/tree_context_menu" %>
  </nav>
</aside>
