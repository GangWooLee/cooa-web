<%# 공통 좌측 사이드바 (컨텍스트 전환형, W2):
     · 사용자 · 내 리뷰 인박스(배지) · 전사 관리 — 항상(불변).
     · 작업실 안(current_workspace) → 작업실 헤더 + "← 모든 작업실" + 그 작업실 서브트리 트리 + 검색 + 새 폴더.
     · 작업실 밖(홈·인박스·전사관리) → 작업실 목록(이름만·클릭=진입). 트리·검색 미렌더. %>
<aside id="app-sidebar" aria-label="주 내비게이션"
       class="fixed bottom-0 left-0 top-[43px] z-50 flex w-[281px] min-w-0 shrink-0 flex-col border-r border-line bg-white shadow-xl lg:static lg:z-auto lg:shadow-none">
  <%# 사용자 → 계정 메뉴. 네이티브 <details>(JS 무의존 — 리뷰 F2: 로그아웃·설정 진입은 Stimulus 실패에도
      살아야 한다. 로그인 페이지 데모 피커와 동일 선례). 트리거=아바타+이름+caret · 패널=헤더→설정→로그아웃. %>
  <details class="relative px-3 pb-3 pt-4">
    <summary aria-haspopup="true"
             class="flex w-full min-w-0 cursor-pointer list-none items-center gap-2 rounded-lg px-1.5 py-1 transition hover:bg-tint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cooa/50 [&::-webkit-details-marker]:hidden">
      <%= avatar(current_account, size: 28, ring: false) %>
      <span class="truncate text-title font-bold text-ink"><%= current_account&.name %></span>
      <span class="ml-auto flex shrink-0 items-center gap-1.5">
        <span class="rounded bg-tint px-1.5 py-0.5 text-caption text-muted">데모</span>
        <%= ui_icon "caret", size: 16, klass: "text-muted" %>
      </span>
    </summary>
    <div role="menu"
         class="absolute inset-x-3 top-full z-30 mt-1 overflow-hidden rounded-lg border border-line bg-white shadow-lg">
      <div class="border-b border-line-soft px-3 py-2">
        <div class="truncate text-body font-bold text-ink"><%= current_account&.name %></div>
        <div class="truncate text-caption text-muted"><%= current_account&.email %></div>
      </div>
      <%= link_to settings_path, role: "menuitem", data: { turbo: false },
            class: "flex items-center gap-2 px-3 py-2 text-body text-ink transition hover:bg-tint" do %>
        <%= ui_icon "settings", size: 16, klass: "text-muted" %><span>계정 설정</span>
      <% end %>
      <%= button_to session_path, method: :delete, form: { class: "block", role: "menuitem" },
            class: "flex w-full items-center gap-2 px-3 py-2 text-left text-body text-ink transition hover:bg-tint hover:text-cooa" do %>
        <%= ui_icon "logout", size: 16, klass: "text-muted" %><span>로그아웃</span>
      <% end %>
    </div>
  </details>

  <%# 내게 요청된 리뷰 수신함(내가 지정 리뷰어인 pending 요청) — 배지 정책 불변 %>
  <% inbox_active = current_page?(reviews_path) %>
  <%= link_to reviews_path, data: { turbo: false }, "aria-current": (inbox_active ? "page" : nil),
        class: "mx-2 mb-1 flex items-center gap-2 rounded-lg px-3 py-2 text-body transition #{inbox_active ? 'bg-accent font-semibold text-cooa' : 'font-medium text-ink hover:bg-tint'}" do %>
    <%= ui_icon "bell", size: 16, klass: (inbox_active ? "text-cooa" : "text-muted") %>
    <span>내 리뷰 인박스</span>
    <%# 배지 정책(REF L493): pending(bg-cooa)은 내 Segment A 전체로 불변. overdue(bg-warn)는 그 부분집합을
        별도 병기 — 내 배정분만(bounded·개인 액션어블). Segment B는 미배지(인박스 행 강조로만). %>
    <% if pending_review_count.positive? %>
      <span class="ml-auto flex items-center gap-1">
        <% if overdue_review_count.positive? %>
          <span title="마감 초과 <%= overdue_review_count %>건" class="flex h-5 min-w-[20px] items-center justify-center rounded-full bg-warn px-1.5 text-caption font-bold text-white"><%= overdue_review_count %></span>
        <% end %>
        <span class="flex h-5 min-w-[20px] items-center justify-center rounded-full bg-cooa px-1.5 text-caption font-bold text-white"><%= pending_review_count %></span>
      </span>
    <% end %>
  <% end %>

  <%# 전사 관리(조직 로스터·초대, Phase 3) — 로스터 열람권자에게만 노출. tenant-wide 읽기권자 OR scoped
      brand_admin(자기 브랜드) — scoped admin은 조직 verb를 통과 못 하므로 can_view_members?로 판정(T3). %>
  <% if can_view_members? %>
    <% members_active = current_page?(members_path) %>
    <%= link_to members_path, data: { turbo: false }, "aria-current": (members_active ? "page" : nil),
          class: "mx-2 mb-1 flex items-center gap-2 rounded-lg px-3 py-2 text-body transition #{members_active ? 'bg-accent font-semibold text-cooa' : 'font-medium text-ink hover:bg-tint'}" do %>
      <%= ui_icon "user", size: 16, klass: (members_active ? "text-cooa" : "text-muted") %>
      <span>구성원</span>
    <% end %>
  <% end %>

  <% if current_workspace %>
    <%# ── 작업실 컨텍스트 ── "← 모든 작업실" 백링크(작업실명은 헤더 타이틀·트리 루트로 표시 — D3 중복 제거).
        border-t 블록은 유지: 전역 내비(사용자·인박스·구성원)와 작업실 트리 사이의 시각 구분자로 남긴다. %>
    <div class="mx-2 mb-1 mt-2 border-t border-line-soft pt-3">
      <%= link_to root_path, data: { turbo: false },
            class: "flex items-center gap-1 px-1 text-caption font-medium text-muted transition hover:text-cooa" do %>
        <span aria-hidden="true">←</span><span>모든 작업실</span>
      <% end %>
    </div>

    <%# 작업실 서브트리 트리 + 아트워크 찾기(클라이언트 필터) %>
    <nav class="mt-1 flex min-w-0 flex-1 flex-col overflow-hidden px-2 pb-6" data-controller="tree-filter tree-ctx">
      <div class="px-4 pt-2 pb-3">
        <div class="relative">
          <input data-tree-filter-target="input" data-action="input->tree-filter#filter keydown->tree-filter#keydown"
                 placeholder="품목코드·품목명 검색" class="w-full rounded-lg bg-tint px-3 py-2 pr-16 text-lead focus:outline-none focus:ring-1 focus:ring-cooa">
          <div class="pointer-events-none absolute inset-y-0 right-2 flex items-center gap-1">
            <span data-tree-filter-target="count" class="hidden rounded bg-tint-2 px-1.5 py-0.5 text-caption font-medium text-muted"></span>
            <button type="button" data-tree-filter-target="clear" data-action="tree-filter#clear" title="검색 지우기" aria-label="검색 지우기"
                    class="pointer-events-auto hidden rounded p-0.5 text-muted transition hover:text-cooa"><%= ui_icon "x", size: 14 %></button>
          </div>
        </div>
      </div>

      <div class="flex-1 overflow-auto">
        <div class="mb-1 flex items-center justify-between px-2">
          <span class="text-meta font-bold text-muted">제품</span>
          <%# origin=side → create가 rename_side로 리다이렉트(사이드바에서 인라인 명명). workspace_id=현재 작업실
              → 새 폴더(트리)는 이 작업실에 귀속되는 새 루트로 생성(컨텍스트 유지). %>
          <%= button_to products_path, params: { product: { kind: "folder" }, origin: "side", workspace_id: current_workspace.id },
                title: "새 폴더", "aria-label": "새 폴더", form: { class: "inline" },
                class: "rounded p-0.5 text-muted transition hover:bg-tint hover:text-cooa" do %><%= ui_icon "plus", size: 14 %><% end %>
        </div>
        <% active_ids = (@product&.self_and_ancestors&.map(&:id) || []) %>
        <%# rename 대상의 조상 <details>를 열어 인라인 입력칸이 보이게 %>
        <% if (rid = params[:rename_side]).present? && (rnode = Product.find_by(id: rid)) %>
          <% active_ids |= rnode.self_and_ancestors.map(&:id) %>
        <% end %>
        <%# 브레드크럼 폴더 클릭(focus) → 해당 폴더 + 조상 펼침 %>
        <% if (fid = params[:focus]).present? && (fnode = Product.find_by(id: fid)) %>
          <% active_ids |= fnode.self_and_ancestors.map(&:id) %>
        <% end %>
        <% context_tree_roots.each do |node| %>
          <%= render "shared/tree_node", node: node, active_ids: active_ids, current_id: @product&.id %>
        <% end %>
        <%# 검색 무매치 시 tree_filter가 노출(그 외엔 hidden). %>
        <%= render "shared/empty_state", variant: :text, title: "일치하는 항목 없음",
              extra: "hidden", data: { tree_filter_target: "empty" } %>
      </div>

      <%= render "shared/tree_context_menu" %>
    </nav>
  <% else %>
    <%# ── 작업실 밖 ── 작업실 목록(이름만·클릭=진입) %>
    <nav class="mt-2 flex min-w-0 flex-1 flex-col overflow-hidden px-2 pb-6">
      <div class="mb-1 px-2">
        <span class="text-meta font-bold text-muted">작업실</span>
      </div>
      <div class="flex-1 overflow-auto">
        <% visible_workspaces.each do |ws| %>
          <%= link_to workspace_path(ws), data: { turbo: false, "workspace-id": ws.id },
                class: "flex min-w-0 items-center gap-2 rounded-md px-2 py-1.5 text-note text-ink transition hover:bg-tint" do %>
            <%= ui_icon "layers", size: 15, klass: "shrink-0 text-cooa" %>
            <span class="min-w-0 flex-1 truncate font-semibold"><%= workspace_label(ws) %></span>
          <% end %>
        <% end %>
        <% if visible_workspaces.empty? %>
          <%= render "shared/empty_state", variant: :text, title: "접근 가능한 작업실이 없습니다" %>
        <% end %>
      </div>
    </nav>
  <% end %>
</aside>
