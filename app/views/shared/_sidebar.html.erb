<%# 공통 좌측 사이드바: 사용자 · 아트워크 찾기(트리 필터) · 제품 디렉터리 트리(노션형) %>
<aside class="hidden w-[281px] min-w-0 shrink-0 flex-col border-r border-line bg-white lg:flex">
  <%# 사용자 %>
  <div class="flex min-w-0 items-center gap-2 px-3 pb-3 pt-4">
    <%= ui_icon "user", size: 24, klass: "shrink-0 text-ink" %>
    <span class="truncate text-[18px] font-bold text-ink"><%= current_user&.name %></span>
    <span class="ml-auto rounded bg-tint px-1.5 py-0.5 text-[10px] text-line">데모</span>
  </div>

  <%# 제품 디렉터리 트리 + 아트워크 찾기(클라이언트 필터) %>
  <nav class="mt-1 flex min-w-0 flex-1 flex-col overflow-hidden px-2 pb-6" data-controller="tree-filter tree-ctx">
    <%# 검색(트리 필터) %>
    <div class="px-[15px] pb-3">
      <input data-tree-filter-target="input" data-action="input->tree-filter#filter" placeholder="아트워크 찾기 (품목코드, 품목명)" class="w-full rounded-lg bg-tint px-3 py-2 text-[15px] outline-none">
    </div>

    <div class="flex-1 overflow-auto">
      <div class="mb-1 flex items-center justify-between px-2">
        <span class="text-[12px] font-bold text-line">제품</span>
        <%# origin=side → create가 rename_side로 리다이렉트(사이드바에서 인라인 명명) %>
        <%= button_to products_path, params: { product: { kind: "folder" }, origin: "side" }, title: "새 폴더",
              form: { class: "inline" },
              class: "rounded p-0.5 text-line transition hover:bg-tint hover:text-cooa" do %><%= ui_icon "plus", size: 14 %><% end %>
      </div>
      <% active_ids = (@product&.self_and_ancestors&.map(&:id) || []) %>
      <%# rename 대상의 조상 <details>를 열어 인라인 입력칸이 보이게 %>
      <% if (rid = params[:rename_side]).present? && (rnode = Product.find_by(id: rid)) %>
        <% active_ids |= rnode.self_and_ancestors.map(&:id) %>
      <% end %>
      <% (@tree_roots || []).each do |node| %>
        <%= render "shared/tree_node", node: node, active_ids: active_ids, current_id: @product&.id %>
      <% end %>
    </div>

    <%# 우클릭 컨텍스트 메뉴(공용 1개) — JS가 커서 위치로 이동·선택 노드에 적용 %>
    <div data-tree-ctx-target="menu" class="fixed z-50 hidden w-44 overflow-hidden rounded-lg border border-line-soft bg-white py-1 text-[13px] shadow-xl">
      <button type="button" data-action="tree-ctx#copyPath" class="flex w-full items-center gap-2 px-3 py-2 text-left text-ink hover:bg-tint"><%= ui_icon "external", size: 14, klass: "text-line" %> 경로 복사</button>
      <button type="button" data-action="tree-ctx#rename" class="flex w-full items-center gap-2 px-3 py-2 text-left text-ink hover:bg-tint"><%= ui_icon "pencil", size: 14, klass: "text-line" %> 이름 변경</button>
      <button type="button" data-action="tree-ctx#del" class="flex w-full items-center gap-2 px-3 py-2 text-left text-warn hover:bg-tint"><%= ui_icon "trash", size: 14 %> 삭제</button>
      <div data-tree-ctx-target="toast" class="hidden border-t border-line-soft px-3 py-1.5 text-[11px] text-line">경로 복사됨</div>
    </div>
  </nav>
</aside>
