<%# 공통 상단바: 로고 · 열린 품목 탭 %>
<header class="flex h-[43px] shrink-0 items-center border-b border-line-soft bg-tint-2">
  <%= link_to root_path, class: "flex h-full w-[100px] shrink-0 items-center pl-3" do %>
    <%= image_tag "cooa/logo.png", class: "h-[26px] w-auto", alt: "COOA" %>
  <% end %>
  <div class="h-full w-px shrink-0 bg-line/70"></div>

  <nav class="flex h-full min-w-0 flex-1 items-center overflow-x-auto">
    <%# 히스토리 탭 — 풀페이지 작업만(버전 v / 비교 c / 스크리닝 s), 쌓인 순서 유지. 우측 페이드 클립, x 호버 노출 %>
    <% (@open_tabs || []).each do |tab| %>
      <div class="group relative flex h-full w-[180px] shrink-0 items-center hover:bg-white/60">
        <%= link_to tab[:path], data: { turbo_action: "advance" }, class: "tab-fade flex min-w-0 flex-1 items-center gap-1.5 overflow-hidden px-3 hover:text-cooa" do %>
          <%= ui_icon (tab[:type] == "s" ? "spark" : tab[:type] == "c" ? "layers" : "doc"), size: 14, klass: "shrink-0 text-line" %>
          <span class="shrink-0 whitespace-nowrap text-[14px] font-medium text-ink">[<%= tab[:code] %>]</span>
          <% if tab[:type] == "c" %>
            <span class="shrink-0 whitespace-nowrap text-[12px] text-line"><%= tab[:from].component.display_name %> <%= tab[:from].vlabel.upcase %>↔<%= tab[:to].vlabel.upcase %></span>
          <% else %>
            <% v = tab[:version] %>
            <span class="shrink-0 whitespace-nowrap text-[12px] text-line"><%= v.component.display_name %> <%= v.vlabel.upcase %></span>
            <% if tab[:type] == "s" %><span class="shrink-0 rounded bg-accent px-1 py-0.5 text-[10px] font-bold text-cooa">스크리닝</span><% end %>
          <% end %>
        <% end %>
        <%= button_to tab_path(tab[:key]), method: :delete, title: "탭 닫기",
              form: { class: "absolute right-1 top-1/2 -translate-y-1/2 opacity-0 transition-opacity duration-150 group-hover:opacity-100" },
              class: "rounded bg-white/90 p-0.5 text-line shadow-sm hover:text-warn" do %><%= ui_icon "x", size: 14 %><% end %>
      </div>
      <div class="h-full w-px shrink-0 bg-line/70"></div>
    <% end %>
  </nav>
</header>
