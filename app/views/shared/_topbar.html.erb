<%# 공통 상단바: 로고 · 사이드바 토글 · 열린 품목 탭 %>
<header class="flex h-[43px] shrink-0 items-center border-b border-line-soft bg-tint-2">
  <%= link_to root_path, class: "flex h-full w-[100px] shrink-0 items-center pl-3" do %>
    <%= image_tag "cooa/logo.png", class: "h-[26px] w-auto", alt: "COOA" %>
  <% end %>
  <div class="h-full w-px shrink-0 bg-line/70"></div>
  <%# 사이드바 접기/펼치기 — 로고 우측, 항상 같은 위치(콘텐츠 비가림) %>
  <button type="button" data-sidebar-target="toggle" data-action="click->sidebar#toggle"
          title="사이드바 접기/펼치기" aria-label="사이드바 열기" aria-controls="app-sidebar" aria-expanded="false"
          class="flex h-full shrink-0 items-center px-3 text-muted transition hover:text-cooa">
    <%= ui_icon "panel-left", size: 18 %>
  </button>
  <div class="h-full w-px shrink-0 bg-line/70"></div>

  <%# 활성/비활성 탭 클래스 — 서버 렌더(SSR 폴백)와 Stimulus 클라이언트 토글이 같은 목록을 쓰도록 1곳에서 정의(드리프트 방지).
      비활성 = 밝은 칩(bg-tint, 회색 상단바 bg-tint-2보다 밝음) + 중립 하단 경계선(line-soft 인셋) → 빈 상단바와 확실히 구분.
      활성(불변) = 흰 배경 + 버건디 하단 인셋. %>
  <% tab_active_class   = "bg-white shadow-[inset_0_-2px_0_0_var(--color-cooa)]" %>
  <% tab_inactive_class = "bg-tint hover:bg-white shadow-[inset_0_-2px_0_0_var(--color-line-soft)]" %>
  <nav class="flex h-full min-w-0 flex-1 items-center overflow-x-auto"
       data-controller="topbar-tabs"
       data-action="turbo:load@document->topbar-tabs#highlight turbo:submit-start->topbar-tabs#closeTab"
       data-topbar-tabs-active-class="<%= tab_active_class %>"
       data-topbar-tabs-inactive-class="<%= tab_inactive_class %>">
    <%# 히스토리 탭 — 풀페이지 작업만(버전 v / 비교 c / 스크리닝 s), 쌓인 순서 유지. 우측 페이드는 호버 시에만 클립, x 호버 노출 %>
    <% header_tabs.each do |tab| %>
      <% tab_active = request.path == tab[:path] %>
      <div data-topbar-tabs-target="tab"
           class="group relative flex h-full w-[180px] shrink-0 items-center <%= tab_active ? tab_active_class : tab_inactive_class %>">
        <%= link_to tab[:path], data: { turbo_action: "advance" }, "aria-current": (tab_active ? "page" : nil), class: "tab-fade flex min-w-0 flex-1 items-center gap-1.5 overflow-hidden px-3 hover:text-cooa" do %>
          <%= ui_icon (tab[:type] == "s" ? "spark" : tab[:type] == "c" ? "layers" : "doc"), size: 14, klass: "shrink-0 text-muted" %>
          <%= product_code_chip(tab[:code], extra: "shrink-0") %>
          <%# 타입 뱃지는 코드 바로 뒤(좌측 unmasked 영역)에 — tab-fade 마스크가 우측에서 잘라 스크리닝/버전 탭이
              동일하게 보이던 문제 해소(ia-nav-2). 긴 '컴포넌트+버전' 라벨은 마스크에 걸려도 타입은 항상 읽힌다. %>
          <% if tab[:type] == "s" %><span class="shrink-0 rounded bg-accent px-1 py-0.5 text-caption font-bold text-cooa">스크리닝</span><% end %>
          <% if tab[:type] == "c" %>
            <span class="shrink-0 whitespace-nowrap text-meta text-muted"><%= tab[:from].component.display_name %> <%= tab[:from].vlabel %>↔<%= tab[:to].vlabel %></span>
          <% else %>
            <% v = tab[:version] %>
            <span class="shrink-0 whitespace-nowrap text-meta text-muted"><%= v.component.display_name %> <%= v.vlabel %></span>
          <% end %>
        <% end %>
        <%= button_to tab_path(tab[:key]), method: :delete, title: "탭 닫기", "aria-label": "탭 닫기",
              form: { class: "absolute right-1 top-1/2 -translate-y-1/2 opacity-0 transition-opacity duration-150 group-hover:opacity-100" },
              class: "touch-target flex items-center justify-center rounded bg-white/90 p-0.5 text-muted shadow-sm hover:text-warn" do %><%= ui_icon "x", size: 14 %><% end %>
      </div>
      <div class="h-full w-px shrink-0 bg-line/70"></div>
    <% end %>
  </nav>
</header>
