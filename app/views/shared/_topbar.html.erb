<%# 공통 상단바: 로고 · 열린 품목 탭 %>
<header class="flex h-[43px] shrink-0 items-center border-b border-line-soft bg-tint-2">
  <%= link_to root_path, class: "flex h-full w-[100px] shrink-0 items-center pl-3" do %>
    <%= image_tag "cooa/logo.png", class: "h-[26px] w-auto", alt: "COOA" %>
  <% end %>
  <div class="h-full w-px shrink-0 bg-line/70"></div>

  <nav class="flex h-full min-w-0 flex-1 items-center overflow-x-auto">
    <% (@open_tabs || []).each do |p| %>
      <%# 탭 컨테이너(div) — 코드=제품 링크, 칩=각 버전 파일 링크(중첩 a 금지 위해 언네스트) %>
      <div class="flex h-full w-[180px] shrink-0 items-center gap-2 px-3 hover:bg-white/60">
        <%= link_to "[#{p.code}]", product_path(p), class: "text-[15px] font-medium text-ink hover:text-cooa" %>
        <% p.components.first(2).each do |c| %>
          <% if (v = c.current_version) %>
            <%= link_to component_version_path(v), title: "#{v.vlabel.upcase} 파일 보기",
                  class: "shrink-0 rounded-md transition hover:ring-2 hover:ring-cooa/40" do %><%= version_chip(v.vlabel.upcase, size: 26) %><% end %>
          <% end %>
        <% end %>
      </div>
      <div class="h-full w-px shrink-0 bg-line/70"></div>
    <% end %>
  </nav>
</header>
