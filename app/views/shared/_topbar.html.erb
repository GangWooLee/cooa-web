<%# 공통 상단바: 로고 · 사이드바 토글 · 열린 품목 탭 %>
<header class="flex h-[43px] shrink-0 items-center border-b border-line-soft bg-tint-2">
  <%= link_to root_path, class: "flex h-full w-[100px] shrink-0 items-center pl-3" do %>
    <%= image_tag "cooa/logo.png", class: "h-[26px] w-auto", alt: "COOA" %>
  <% end %>
  <div class="h-full w-px shrink-0 bg-line/70"></div>
  <%# 사이드바 접기/펼치기 — 로고 우측, 항상 같은 위치(콘텐츠 비가림) %>
  <button type="button" data-action="click->sidebar#toggle" title="사이드바 접기/펼치기" aria-label="사이드바 접기/펼치기"
          class="flex h-full shrink-0 items-center px-3 text-muted transition hover:text-cooa">
    <%= ui_icon "panel-left", size: 18 %>
  </button>
  <div class="h-full w-px shrink-0 bg-line/70"></div>

  <nav class="flex h-full min-w-0 flex-1 items-center overflow-x-auto">
    <%# 히스토리 탭 — 풀페이지 작업만(버전 v / 비교 c / 스크리닝 s), 쌓인 순서 유지. 우측 페이드 클립, x 호버 노출 %>
    <% header_tabs.each do |tab| %>
      <% tab_active = request.path == tab[:path] %>
      <div class="group relative flex h-full w-[180px] shrink-0 items-center <%= tab_active ? "bg-white shadow-[inset_0_-2px_0_0_var(--color-cooa)]" : "hover:bg-white/60" %>">
        <%= link_to tab[:path], data: { turbo_action: "advance" }, "aria-current": (tab_active ? "page" : nil), class: "tab-fade flex min-w-0 flex-1 items-center gap-1.5 overflow-hidden px-3 hover:text-cooa" do %>
          <%= ui_icon (tab[:type] == "s" ? "spark" : tab[:type] == "c" ? "layers" : "doc"), size: 14, klass: "shrink-0 text-muted" %>
          <span class="shrink-0 whitespace-nowrap text-note font-medium text-ink">[<%= tab[:code] %>]</span>
          <% if tab[:type] == "c" %>
            <span class="shrink-0 whitespace-nowrap text-meta text-muted"><%= tab[:from].component.display_name %> <%= tab[:from].vlabel %>↔<%= tab[:to].vlabel %></span>
          <% else %>
            <% v = tab[:version] %>
            <span class="shrink-0 whitespace-nowrap text-meta text-muted"><%= v.component.display_name %> <%= v.vlabel %></span>
            <% if tab[:type] == "s" %><span class="shrink-0 rounded bg-accent px-1 py-0.5 text-caption font-bold text-cooa">스크리닝</span><% end %>
          <% end %>
        <% end %>
        <%= button_to tab_path(tab[:key]), method: :delete, title: "탭 닫기",
              form: { class: "absolute right-1 top-1/2 -translate-y-1/2 opacity-0 transition-opacity duration-150 group-hover:opacity-100" },
              class: "rounded bg-white/90 p-0.5 text-muted shadow-sm hover:text-warn" do %><%= ui_icon "x", size: 14 %><% end %>
      </div>
      <div class="h-full w-px shrink-0 bg-line/70"></div>
    <% end %>
  </nav>
</header>
