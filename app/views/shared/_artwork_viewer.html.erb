<%# 재사용 아트워크 뷰어 (단일/듀얼 pane).
     locals: panes [{image_src,label,boxes}]  또는  image_src + boxes(단일).  drawable, autofocus, height_class %>
<%
  panes     = local_assigns[:panes] || [{ image_src: local_assigns[:image_src], boxes: local_assigns.fetch(:boxes, []) }]
  drawable  = local_assigns.fetch(:drawable, false)
  autofocus = local_assigns.fetch(:autofocus, false)
  all_boxes = panes.flat_map { |pn| pn[:boxes] || [] }.uniq { |b| b[:seq] }.sort_by { |b| b[:seq] }
  mini      = panes.last
%>
<div data-controller="artwork-viewer"
     data-artwork-viewer-drawable-value="<%= drawable %>"
     data-artwork-viewer-autofocus-value="<%= autofocus %>"
     class="relative <%= local_assigns[:height_class] || 'h-full' %> w-full select-none overflow-hidden rounded-xl border border-line bg-tint-2"
     style="touch-action:none">

  <%# pane들 (1개=단일, 2개=이전|현재) %>
  <div class="flex h-full w-full">
    <% panes.each_with_index do |pn, pi| %>
      <div data-artwork-viewer-target="pane" class="relative min-w-0 flex-1 overflow-hidden <%= 'border-l-2 border-line' if pi.positive? %>">
        <% if pn[:label].present? %>
          <div class="av-ui pointer-events-none absolute left-2 top-2 z-10 rounded-md bg-white/85 px-2 py-0.5 text-xs font-bold <%= pi == panes.size - 1 ? 'text-cooa' : 'text-ink' %>"><%= pn[:label] %></div>
        <% end %>
        <div data-artwork-viewer-target="stage" class="absolute left-0 top-0 origin-top-left">
          <img data-artwork-viewer-target="image" src="<%= pn[:image_src] %>" class="block max-w-none" draggable="false" alt="아트워크">
          <% (pn[:boxes] || []).each do |b| %>
            <button type="button" data-artwork-viewer-target="box"
                    data-seq="<%= b[:seq] %>" data-x="<%= b[:x] %>" data-y="<%= b[:y] %>" data-w="<%= b[:w] %>" data-h="<%= b[:h] %>"
                    data-action="click->artwork-viewer#focusBox"
                    class="absolute rounded-[3px] border-2 transition-[opacity,box-shadow]"
                    style="left:<%= b[:x] %>%;top:<%= b[:y] %>%;width:<%= b[:w] %>%;height:<%= b[:h] %>%;border-color:<%= b[:color] %>;background:<%= b[:color] %>1f">
              <span class="absolute -left-2.5 -top-2.5 flex h-5 w-5 items-center justify-center rounded-full text-[11px] font-bold leading-none text-white shadow" style="background:<%= b[:color] %>"><%= b[:label] || b[:seq] %></span>
            </button>
          <% end %>
          <% if drawable && pi == panes.size - 1 %>
            <div data-artwork-viewer-target="draftBox" class="pointer-events-none absolute hidden rounded-[3px] border-2 border-dashed border-cooa" style="background:#8e030022"></div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 줌 툴바 (1개) %>
  <div class="av-ui absolute right-3 top-3 flex flex-col overflow-hidden rounded-lg border border-line bg-white/95 text-ink shadow">
    <button type="button" data-action="artwork-viewer#zoomIn"  class="flex h-8 w-8 items-center justify-center hover:bg-tint">＋</button>
    <button type="button" data-action="artwork-viewer#zoomOut" class="flex h-8 w-8 items-center justify-center border-t border-line-soft hover:bg-tint">－</button>
    <button type="button" data-action="artwork-viewer#fit"     class="flex h-8 w-8 items-center justify-center border-t border-line-soft text-[11px] hover:bg-tint" title="전체 보기">fit</button>
  </div>

  <%# 미니맵 (1개) %>
  <div class="av-ui absolute bottom-3 left-3 rounded-lg border border-line bg-white/95 p-1 shadow">
    <div data-artwork-viewer-target="minimap" data-action="click->artwork-viewer#minimapClick"
         class="relative w-[150px] cursor-crosshair overflow-hidden rounded">
      <img src="<%= mini[:image_src] %>" class="block w-full" draggable="false" alt="">
      <% (mini[:boxes] || []).each do |b| %>
        <span class="absolute" style="left:<%= b[:x] %>%;top:<%= b[:y] %>%;width:<%= b[:w] %>%;height:<%= b[:h] %>%;background:<%= b[:color] %>"></span>
      <% end %>
      <div data-artwork-viewer-target="viewport" class="pointer-events-none absolute border-2 border-cooa" style="background:#8e030018"></div>
    </div>
  </div>

  <%# 번호 버튼 (1개) %>
  <% if all_boxes.any? %>
    <div class="av-ui absolute bottom-3 left-1/2 flex max-w-[55%] -translate-x-1/2 flex-wrap items-center justify-center gap-1 rounded-full border border-line bg-white/95 px-2 py-1 shadow">
      <% all_boxes.each do |b| %>
        <button type="button" data-seq="<%= b[:seq] %>" data-action="artwork-viewer#focusSeq"
                class="av-seq flex h-7 w-7 items-center justify-center rounded-full border-2 text-[13px] font-bold transition"
                style="border-color:<%= b[:color] %>;color:<%= b[:color] %>"><%= b[:label] || b[:seq] %></button>
      <% end %>
    </div>
  <% end %>

  <% if drawable %>
    <div class="av-ui absolute left-1/2 top-3 -translate-x-1/2 rounded-full bg-ink/75 px-3 py-1 text-xs text-white">현재 뷰에서 Shift+드래그로 영역 표시</div>
  <% end %>
</div>
