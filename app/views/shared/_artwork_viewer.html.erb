<%# 재사용 아트워크 뷰어 (단일/듀얼 pane). 3구역: 상단 바 / 캔버스 / 하단 바.
     locals: panes [{image_src,thumb_src,is_pdf,label,boxes}]  또는  image_src(+thumb_src,is_pdf) + boxes(단일).
     image_src=메인 렌더 소스(PDF blob 또는 이미지), thumb_src=미니맵·필름스트립용 래스터(PDF=preview PNG),
     is_pdf=true면 <canvas>에 PDF.js 렌더. worker_src=PDF.js worker asset_path. drawable, autofocus, height_class %>
<%
  raw_panes = local_assigns[:panes] || [{ image_src: local_assigns[:image_src], thumb_src: local_assigns[:thumb_src],
                                          is_pdf: local_assigns[:is_pdf], boxes: local_assigns.fetch(:boxes, []) }]
  panes     = raw_panes.map { |pn| pn.merge(thumb_src: pn[:thumb_src] || (pn[:is_pdf] ? nil : pn[:image_src])) }
  drawable  = local_assigns.fetch(:drawable, false)
  autofocus = local_assigns.fetch(:autofocus, false)
  worker_src = local_assigns[:worker_src]
  all_boxes = panes.flat_map { |pn| pn[:boxes] || [] }.uniq { |b| b[:seq] }.sort_by { |b| b[:seq] }
  mini      = panes.last
%>
<div data-controller="artwork-viewer"
     data-artwork-viewer-drawable-value="<%= drawable %>"
     data-artwork-viewer-autofocus-value="<%= autofocus %>"
     data-artwork-viewer-worker-src-value="<%= worker_src %>"
     class="flex <%= local_assigns[:height_class] || 'h-full' %> w-full min-w-0 select-none flex-col">

  <%# ── 상단 바: 줌·영역표시(좌) + 피드백 번호(우) ── %>
  <div class="av-ui flex items-center justify-between gap-2 px-0.5 pb-2">
    <% if local_assigns.fetch(:zoom, true) || drawable %>
      <div class="flex shrink-0 items-center gap-2">
        <% if local_assigns.fetch(:zoom, true) %>
          <%# 관례 순서: 확대(＋) 선두 → 축소(－) → 전체 %>
          <div class="flex shrink-0 items-center overflow-hidden rounded-lg border border-line bg-white text-ink shadow-sm">
            <button type="button" data-action="artwork-viewer#zoomIn"  aria-label="확대" class="touch-target flex h-7 w-8 items-center justify-center hover:bg-tint"><%= ui_icon "plus", size: 15 %></button>
            <button type="button" data-action="artwork-viewer#zoomOut" aria-label="축소" class="touch-target flex h-7 w-8 items-center justify-center border-l border-line-soft hover:bg-tint"><%= ui_icon "minus", size: 15 %></button>
            <button type="button" data-action="artwork-viewer#fit"     class="touch-target flex h-7 items-center justify-center border-l border-line-soft px-2 text-meta hover:bg-tint" title="전체 보기">전체</button>
          </div>
        <% end %>
        <% if drawable %>
          <%# 영역 표시 = 드래그 드로우 모드 토글(Shift+드래그와 병행). aria-pressed=활성 표시. %>
          <button type="button" data-action="artwork-viewer#toggleDraw" data-artwork-viewer-target="drawToggle" aria-pressed="false"
                  title="영역 표시 — 드래그로 피드백 박스 지정(Shift+드래그 병행)"
                  class="touch-target flex h-7 shrink-0 items-center gap-1 rounded-lg border border-line bg-white px-2 text-meta text-ink shadow-sm transition hover:bg-tint aria-pressed:border-cooa aria-pressed:bg-accent aria-pressed:text-cooa">
            <%= ui_icon "pin", size: 14 %> 영역 표시
          </button>
        <% end %>
      </div>
    <% end %>
    <% if all_boxes.any? %>
      <div class="ml-auto flex min-w-0 items-center gap-1.5">
        <span class="shrink-0 text-caption font-bold text-muted">피드백</span>
        <%# 단행 고정 + 수평 스크롤 — 피드백이 많아도 상단바 높이 안정(다중 줄 래핑 제거). 좁은 뷰포트 우측 페이드 단서(responsive-6). %>
        <div class="scroll-fade-x flex min-w-0 flex-nowrap items-center gap-1 overflow-x-auto scrollbar-slim">
          <% all_boxes.each do |b| %>
            <button type="button" data-seq="<%= b[:seq] %>" data-action="artwork-viewer#focusSeq"
                    aria-label="<%= b[:aria] || "피드백 #{b[:label] || b[:seq]}" %>"
                    class="av-seq touch-target flex h-7 w-7 shrink-0 items-center justify-center rounded-full border-2 text-body font-bold transition"
                    style="border-color:<%= b[:color] %>;color:var(--color-ink)"><%= b[:label] || b[:seq] %></button>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── 버전 라벨 띠 (각 pane 우측 상단·바깥) ── %>
  <% if panes.any? { |pn| pn[:label].present? } %>
    <div class="av-ui flex pb-1.5">
      <% panes.each_with_index do |pn, pi| %>
        <div class="flex min-w-0 flex-1 justify-start <%= pi.positive? ? 'pl-2' : 'pl-1' %>">
          <% if pn[:label].present? %>
            <span class="rounded-md bg-tint px-2 py-0.5 text-meta font-bold text-ink/75"><%= pn[:label] %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── 캔버스 (깨끗) ── %>
  <div data-artwork-viewer-target="canvas"
       class="relative min-h-0 flex-1 overflow-hidden rounded-xl border border-line bg-tint-2"
       style="touch-action:none">
    <%# 듀얼 pane: lg 미만 세로 스택(각 판 전체 폭) / lg+ 가로 병치. 좌표계는 판 상대(각 stage 동일 transform,
        판 크기 동일 flex-1) — this.rect=판0 기준이 방향 무관하게 성립(resize 리스너가 브레이크포인트 교차 시 refit). responsive-1 %>
    <div class="flex h-full w-full flex-col lg:flex-row">
      <% panes.each_with_index do |pn, pi| %>
        <div data-artwork-viewer-target="pane" class="relative h-full min-h-0 min-w-0 flex-1 overflow-hidden <%= 'border-t-2 border-line lg:border-t-0 lg:border-l-2' if pi.positive? %>">
            <div data-artwork-viewer-target="stage" class="absolute left-0 top-0 origin-top-left">
              <% if pn[:is_pdf] %>
                <%# PDF: PDF.js가 이 캔버스에 페이지1을 벡터 렌더(줌 시 재렌더). 오버레이 %-박스는 이미지와 동일. %>
                <canvas data-artwork-viewer-target="page" data-pdf-src="<%= pn[:image_src] %>" class="block max-w-none"></canvas>
              <% else %>
                <img data-artwork-viewer-target="image" src="<%= pn[:image_src] %>" class="block max-w-none" draggable="false" alt="아트워크">
              <% end %>
              <% (pn[:boxes] || []).each do |b| %>
                <% box_fill = b[:fill] || "color-mix(in srgb, #{b[:color]} 12%, transparent)" %>
                <button type="button" data-artwork-viewer-target="box"
                        data-seq="<%= b[:seq] %>" data-x="<%= b[:x] %>" data-y="<%= b[:y] %>" data-w="<%= b[:w] %>" data-h="<%= b[:h] %>"
                        data-action="click->artwork-viewer#focusBox"
                        aria-label="<%= b[:aria] || "피드백 #{b[:label] || b[:seq]}" %>"
                        class="absolute rounded-[3px] border-2 transition-[opacity,box-shadow]"
                        style="left:<%= b[:x] %>%;top:<%= b[:y] %>%;width:<%= b[:w] %>%;height:<%= b[:h] %>%;border-color:<%= b[:color] %>;background:<%= box_fill %>">
                  <%= seq_badge(b[:label] || b[:seq], color: b[:color], size: :md, extra: "absolute -left-2.5 -top-2.5 shadow") %>
                </button>
              <% end %>
              <% if drawable && pi == panes.size - 1 %>
                <div data-artwork-viewer-target="draftBox" class="pointer-events-none absolute hidden rounded-[3px] border-2 border-dashed border-cooa bg-cooa/15"></div>
              <% end %>
            </div>
        </div>
      <% end %>
    </div>

    <% if drawable %>
      <div data-artwork-viewer-target="hint"
           class="av-ui pointer-events-none absolute left-1/2 top-3 -translate-x-1/2 rounded-full bg-ink/80 px-3 py-1 text-meta text-white shadow transition-opacity duration-500"><b>영역 표시</b> 버튼 또는 Shift+드래그로 피드백 영역 지정</div>
    <% end %>
    <%# 멀티페이지 PDF 안전 경고(JS가 numPages>1이면 표시) — v1은 첫 페이지만 렌더 %>
    <div data-artwork-viewer-target="notice"
         class="av-ui pointer-events-none absolute right-3 top-3 hidden max-w-[70%] rounded-lg bg-warn/95 px-2.5 py-1 text-caption font-bold text-white shadow"></div>
  </div>

  <%# ── 하단 바: 미니맵(좌) + 썸네일 필름스트립(우) ── %>
  <div class="av-ui mt-2 flex items-stretch gap-2">
    <div class="shrink-0 rounded-lg border border-line bg-white p-1 shadow-sm">
      <div data-artwork-viewer-target="minimap" data-action="click->artwork-viewer#minimapClick"
           class="relative w-[140px] cursor-crosshair overflow-hidden rounded">
        <%# 미니맵 이미지는 첫 pane(=컨트롤러 nat 기준)과 일치시켜 뷰포트 정렬 보장. PDF는 preview PNG(thumb_src). %>
        <% if panes.first[:thumb_src].present? %>
          <img src="<%= panes.first[:thumb_src] %>" class="block w-full" draggable="false" alt="">
        <% else %>
          <div class="flex aspect-[16/9] w-full items-center justify-center bg-tint-2 text-meta text-muted">미리보기 없음</div>
        <% end %>
        <% (panes.first[:boxes] || []).each do |b| %>
          <span class="absolute" style="left:<%= b[:x] %>%;top:<%= b[:y] %>%;width:<%= b[:w] %>%;height:<%= b[:h] %>%;background:<%= b[:color] %>"></span>
        <% end %>
        <div data-artwork-viewer-target="viewport" class="pointer-events-none absolute border-2 border-cooa bg-cooa/10"></div>
      </div>
    </div>

    <% if all_boxes.any? %>
      <div class="flex min-w-0 flex-1 items-center gap-2 overflow-x-auto rounded-lg border border-line bg-white px-2 shadow-sm">
        <% all_boxes.each do |b| %>
          <%# aspect-ratio는 서버 근사(IMG_RATIO) → 뷰어 ready 시 correctThumbAspects가 실제 nat 비율로 교정 %>
          <button type="button" data-seq="<%= b[:seq] %>" data-w="<%= b[:w] %>" data-h="<%= b[:h] %>" data-action="artwork-viewer#focusSeq"
                  class="av-thumb relative shrink-0 overflow-hidden rounded border-2 transition"
                  style="height:54px;aspect-ratio:<%= box_aspect(b[:w], b[:h]) %>;border-color:<%= b[:color] %>;<%= crop_bg(mini[:thumb_src], b[:x], b[:y], b[:w], b[:h]) %>"
                  aria-label="<%= b[:aria] || "피드백 #{b[:label] || b[:seq]}" %>" title="피드백 <%= b[:label] || b[:seq] %>">
            <%= seq_badge(b[:label] || b[:seq], color: b[:color], size: :sm, extra: "absolute left-0.5 top-0.5 shadow") %>
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
