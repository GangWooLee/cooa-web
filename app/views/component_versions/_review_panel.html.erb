<%# 버전 리뷰 패널(리프레임) — 이 버전의 최신 스크리닝을 대상으로 리뷰 요청/검토 확인/변경 요청.
    규제 전자서명 없음(서명·step-up 폐지). 신원 SoD: 요청자는 본인 요청을 확인할 수 없음. %>
<div class="border-t border-line p-3">
  <div class="mb-2 text-[13px] font-bold text-ink">버전 리뷰</div>
  <% if @latest_run.nil? %>
    <p class="text-[12px] text-line">
      <%= link_to "인허가 스크리닝", screening_component_version_path(@version), class: "font-bold text-cooa underline" %> 실행 후 리뷰를 요청할 수 있습니다.
    </p>
  <% else %>
    <% req = @approval_request %>
    <% if req.nil? %>
      <% if policy(@latest_run).submit_for_approval? %>
        <%= button_to "리뷰 요청", approval_requests_path(screening_run_id: @latest_run.id),
              class: "w-full rounded-lg bg-cooa-gradient px-4 py-2.5 text-[13px] font-bold text-white" %>
      <% else %>
        <p class="text-[12px] text-line">리뷰 요청 권한이 없습니다.</p>
      <% end %>
    <% elsif req.pending? %>
      <div class="space-y-2">
        <div class="flex items-center justify-between">
          <span class="text-[13px] font-bold text-ink">리뷰 대기</span>
          <span class="rounded-full px-2 py-0.5 text-[11px] font-bold text-white" style="background:#d99a00">요청됨</span>
        </div>
        <div class="flex items-center gap-1.5 text-[12px] text-line">요청자 <%= avatar(req.submitter, size: 18) %> <span class="font-medium text-ink"><%= req.submitter.name %></span></div>
        <% if policy(req).confirm_review? %>
          <div class="space-y-1.5 pt-1">
            <%= button_to "✓ 검토 확인", confirm_approval_request_path(req),
                  class: "w-full cursor-pointer rounded-lg bg-cooa-gradient px-3 py-2 text-[13px] font-bold text-white" %>
            <%= button_to "변경 요청", request_changes_approval_request_path(req),
                  class: "w-full rounded-lg border border-warn px-3 py-2 text-[13px] font-bold text-warn",
                  form: { data: { turbo_confirm: "이 버전에 변경을 요청하시겠습니까?" } } %>
          </div>
        <% elsif current_user == req.submitter %>
          <p class="pt-1 text-[11px] text-line">본인이 요청한 리뷰는 본인이 확인할 수 없습니다 (SoD).</p>
        <% else %>
          <p class="pt-1 text-[11px] text-line">검토 가능한 리뷰어를 기다리는 중입니다.</p>
        <% end %>
      </div>
    <% elsif req.reviewed? %>
      <% step = req.approval_steps.find_by(decision: "confirmed") %>
      <div class="rounded-lg p-2.5 text-[13px] font-bold" style="color:#5f8f2e;background:#eef6e3">
        ✓ 검토 확인됨<% if step&.approver %> · <%= step.approver.name %><% end %><% if step&.acted_at %> · <%= step.acted_at.strftime("%Y.%m.%d %H:%M") %><% end %>
      </div>
    <% elsif req.changes_requested? %>
      <% step = req.approval_steps.find_by(decision: "changes_requested") %>
      <div class="rounded-lg p-2.5 text-[13px]" style="color:#b3261e;background:#ffe9e9">
        <span class="font-bold">✗ 변경 요청됨</span><% if step&.approver %> · <%= step.approver.name %><% end %>
        <% if step&.reason.present? %><p class="mt-1 text-[12px] text-ink"><%= step.reason %></p><% end %>
      </div>
    <% end %>
  <% end %>
</div>
