<%# new/edit 공유 폼 — 파일·변경사유·현재 지정. multipart. %>
<% persisted  = @version.persisted? %>
<% url        = persisted ? component_version_path(@version) : component_component_versions_path(@component) %>
<% method     = persisted ? :patch : :post %>
<% cancel_url = persisted ? component_version_path(@version) : product_path(@component.product) %>

<%# 제출 시 버튼 로딩(스피너 + "추가 중…"/"저장 중…") — 업로드 왕복 동안 중복 제출 방지. 422 재렌더/리다이렉트가 새 버튼을 그려 리셋. %>
<%= form_with model: @version, url: url, method: method, multipart: true, class: "space-y-5",
      data: { controller: "submit-loading", action: "submit->submit-loading#onSubmit", submit_loading_label_value: (persisted ? "저장 중…" : "추가 중…") } do |f| %>
  <% if @version.errors.any? %>
    <div id="version-form-errors" role="alert" class="flex gap-2 rounded-lg border border-warn/50 p-3 text-body text-ink">
      <%= ui_icon "warn", size: 16, klass: "mt-0.5 shrink-0 text-warn" %>
      <ul class="list-disc pl-4 font-medium">
        <% @version.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>
  <%# 실패 필드 → aria-invalid + 오류 요약(role=alert)으로 aria-describedby 연결. %>
  <% invalid_attrs = ->(attr) { @version.errors[attr].any? ? { "aria-invalid": "true", "aria-describedby": "version-form-errors" } : {} } %>

  <div>
    <%# 신규(!persisted)만 아트워크 필수 — 별표(3중 신호: 색+기호+SR용 '필수')와 client required. edit는 기존 파일 유지 허용이라 미적용(forms-3). %>
    <label class="block text-body font-bold text-ink">아트워크 파일<% unless persisted %> <span class="text-cooa" aria-hidden="true">*</span><span class="sr-only">필수</span><% end %> <span class="font-normal text-muted">· PDF·PNG·JPG·WEBP · 30MB 이하</span></label>
    <%# blob.persisted? 가드: 검증 실패(422) 재렌더 시 거부된 미저장 업로드가 "현재 파일"로 뜨거나
        미서명 blob의 signed_id로 500이 나는 것 방지(EC-4) — 저장된 기존 첨부만 표시. %>
    <% if persisted && @version.artwork.attached? && @version.artwork.blob&.persisted? %>
      <div class="mt-2 flex items-center gap-2 text-meta text-muted">
        <% if @version.artwork_pdf? %>
          <span class="flex h-16 w-12 items-center justify-center rounded border border-line-soft bg-tint-2"><%= ui_icon "doc", size: 22, klass: "text-muted" %></span>
          <span class="font-medium text-ink"><%= @version.artwork.filename %></span>
        <% else %>
          <img src="<%= artwork_src(@version) %>" class="h-16 w-auto rounded border border-line-soft" alt="현재 아트워크">
        <% end %>
        <span>현재 파일 · 새로 선택하지 않으면 유지됩니다</span>
      </div>
    <% end %>
    <%# file: 셀렉터 버튼을 ui_button primary와 동형으로 정렬(bg-cooa·rounded-lg·hover:bg-cooa-dark) — M6 %>
    <%= f.file_field :artwork, accept: "application/pdf,image/png,image/jpeg,image/webp", required: !persisted,
          class: "mt-2 block w-full text-body text-ink file:mr-3 file:cursor-pointer file:rounded-lg file:border-0 file:bg-cooa file:px-3 file:py-2 file:font-bold file:text-white file:transition file:hover:bg-cooa-dark",
          **invalid_attrs.(:artwork) %>
  </div>

  <div>
    <label class="block text-body font-bold text-ink">변경사유</label>
    <%= f.text_area :change_reason, rows: 3, placeholder: "이 버전에서 무엇이 달라졌나요?",
          class: "mt-2 w-full rounded-lg border border-line-soft px-3 py-2 text-note focus:border-cooa focus:outline-none focus:ring-1 focus:ring-cooa",
          **invalid_attrs.(:change_reason) %>
  </div>

  <label class="flex items-center gap-2 text-note text-ink">
    <%= f.check_box :current, class: "h-4 w-4 rounded border-line text-cooa" %>
    이 버전을 <b>현재 버전</b>으로 지정
  </label>

  <div class="flex items-center gap-2 pt-1">
    <%= ui_button(persisted ? "저장" : "버전 추가", type: "submit", data: { submit_loading_target: "button" }) %>
    <%= ui_button "취소", variant: :ghost, href: cancel_url, data: { turbo_frame: "_top" } %>
  </div>
<% end %>
