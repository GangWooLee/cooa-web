<% content_for :title, "#{@component.display_name} #{@version.vlabel.upcase} · #{@product.code}" %>
<div class="flex h-full flex-col">
  <%# 헤더: 브레드크럼 + 버전 스위처 + 이전/다음 %>
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-line-soft px-5 py-3">
    <div class="flex items-center gap-2 text-sm">
      <%= node_breadcrumb(@product, trailing: "#{@component.display_name} #{@version.vlabel.upcase}") %>
      <% if @version.current? %>
        <span class="rounded bg-tint px-1.5 py-0.5 text-[10px] font-bold text-line">현재 버전</span>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <%# 형제 버전 스위처 (클릭 = 해당 버전 파일 보기) %>
      <div class="flex items-center gap-1">
        <% @siblings.each do |sib| %>
          <%= link_to component_version_path(sib), title: "#{sib.vlabel.upcase} 보기",
                class: "shrink-0 rounded-lg p-0.5 transition hover:bg-accent hover:ring-2 hover:ring-cooa/40 #{'ring-2 ring-cooa' if sib.id == @version.id}" do %>
            <%= version_chip(sib.vlabel.upcase, size: 28, active: sib.id == @version.id) %>
          <% end %>
        <% end %>
      </div>
      <%= link_to new_component_component_version_path(@component), title: "새 버전 추가",
            class: "ml-1 inline-flex h-7 items-center gap-1 rounded-lg border border-cooa bg-white px-2 text-[12px] font-bold text-cooa transition hover:bg-cooa hover:text-white" do %>
        <%= ui_icon "plus", size: 14 %> 새 버전
      <% end %>
    </div>
  </div>

  <%# 본문: 좌 아트워크(피드백 박스·Shift+드래그) / 우 메타+피드백+리뷰 %>
  <div data-controller="version-feedback"
       data-action="artwork-viewer:focus->version-feedback#onFocus artwork-viewer:draw->version-feedback#onDraw"
       class="flex min-h-0 flex-1 flex-col lg:flex-row">
    <div class="min-h-0 min-w-0 flex-1 p-3" style="min-height:380px">
      <% if artwork?(@version) %>
        <%= render "shared/artwork_viewer", image_src: artwork_src(@version),
              is_pdf: @version.artwork_pdf?, thumb_src: artwork_thumb_src(@version),
              worker_src: asset_path("pdfjs.worker.min.js"),
              boxes: annotation_boxes(@annotations), drawable: policy(@version).leave_feedback?, zoom: true %>
      <% else %>
        <div class="flex h-full flex-col items-center justify-center gap-3 rounded-xl border border-dashed border-line bg-tint-2 text-line">
          <%= ui_icon "doc", size: 32, klass: "text-line" %>
          <p>아트워크 이미지 없음 · <%= @component.display_name %> <%= @version.vlabel.upcase %></p>
          <%= link_to "파일 추가", edit_component_version_path(@version),
                class: "inline-flex items-center gap-1 rounded-lg bg-cooa px-3 py-1.5 text-[13px] font-bold text-white" %>
        </div>
      <% end %>
    </div>

    <aside class="flex w-full shrink-0 flex-col border-t border-line bg-white lg:w-[380px] lg:border-l lg:border-t-0">
      <%# 메타(컴팩트) %>
      <div class="border-b border-line-soft p-4">
        <div class="flex items-center gap-2">
          <%= version_chip(@version.vlabel.upcase, size: 34, active: @version.current?) %>
          <div class="min-w-0">
            <div class="text-base font-bold text-ink"><%= @component.display_name %> <%= @version.vlabel.upcase %></div>
            <div class="text-[12px] text-line"><%= @product.code %> · <%= @product.name %></div>
          </div>
        </div>
        <% if @version.change_reason.present? %>
          <div class="mt-3 rounded-lg bg-accent p-3">
            <div class="text-[11px] font-bold text-cooa">변경사유</div>
            <p class="mt-1 text-[13px] leading-relaxed text-ink/85"><%= @version.change_reason %></p>
          </div>
        <% end %>
        <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5 text-[13px]">
          <% if @version.created_by %>
            <dt class="font-bold text-line">작성자</dt>
            <dd class="flex items-center gap-1.5"><%= avatar(@version.created_by, size: 20) %><span class="text-ink"><%= @version.created_by.name %></span></dd>
          <% end %>
          <dt class="font-bold text-line">생성일</dt>
          <dd class="text-ink"><%= @version.created_at.strftime("%Y.%m.%d %H:%M") %></dd>
          <% if @version.ingredients.any? %>
            <dt class="font-bold text-line">전성분</dt>
            <dd class="text-ink"><%= @version.ingredients.size %>종</dd>
          <% end %>
        </dl>
      </div>

      <%# 피드백(검토 단위 ②: 누구나 남기고, 리뷰어가 반영 확인) — 단일 버전에서도 자유롭게 %>
      <div data-version-feedback-target="list" class="flex min-h-0 flex-1 flex-col">
        <div class="border-b border-line-soft p-3">
          <h3 class="text-base font-bold text-ink">피드백 <span class="text-line">(<%= @annotations.size %>)</span></h3>
          <p class="text-xs text-line">
            <% if policy(@version).leave_feedback? %>아트워크에서 <b>Shift+드래그</b>로 영역을 표시해 남기세요 · <% end %>
            <b style="color:#5f8f2e"><%= @annotations.count(&:resolved?) %> 반영</b> / <b style="color:#8e0300"><%= @annotations.count(&:open?) %> 미반영</b>
          </p>
        </div>
        <div class="min-h-0 flex-1 space-y-2 overflow-auto p-3">
          <% if @annotations.any? %>
            <% @annotations.each do |a| %>
              <button type="button" data-seq="<%= a.seq %>" data-action="version-feedback#focusFromList"
                      class="block w-full rounded-lg border border-line-soft p-2.5 text-left transition hover:border-cooa">
                <div class="flex items-center justify-between">
                  <span class="flex items-center gap-2">
                    <span class="flex h-5 w-5 items-center justify-center rounded-full text-[11px] font-bold text-white" style="background:<%= a.box_color %>"><%= a.seq %></span>
                    <span class="rounded bg-tint px-1.5 py-0.5 text-[11px] text-ink/70"><%= a.category %></span>
                  </span>
                  <span class="rounded-full px-2 py-0.5 text-[11px] font-bold" style="color:<%= a.status_meta[:color] %>;background:<%= a.status_meta[:bg] %>"><%= a.status_meta[:label] %></span>
                </div>
                <p class="mt-1 line-clamp-2 text-[12.5px] text-ink/80"><%= a.comments.first&.body %></p>
              </button>
            <% end %>
          <% else %>
            <p class="py-8 text-center text-[13px] text-line">아직 피드백이 없습니다.</p>
          <% end %>
        </div>
      </div>

      <%# 피드백 상세(어노테이션별, 기본 숨김) %>
      <% @annotations.each do |a| %>
        <div data-version-feedback-target="detail" data-seq="<%= a.seq %>" class="hidden min-h-0 flex-1 flex-col">
          <div class="flex items-center gap-2 border-b border-line-soft p-3">
            <button type="button" data-action="version-feedback#backToList" class="text-sm text-line hover:text-cooa">← 목록</button>
            <span class="flex h-5 w-5 items-center justify-center rounded-full text-[11px] font-bold text-white" style="background:<%= a.box_color %>"><%= a.seq %></span>
            <span class="rounded bg-tint px-1.5 py-0.5 text-[11px] text-ink/70"><%= a.category %></span>
            <span class="ml-auto rounded-full px-2 py-0.5 text-[11px] font-bold" style="color:<%= a.status_meta[:color] %>;background:<%= a.status_meta[:bg] %>"><%= a.status_meta[:label] %></span>
          </div>
          <div class="min-h-0 flex-1 overflow-auto p-3">
            <p class="mb-2 text-[11px] text-line">← 캔버스에서 이 영역이 확대됩니다.</p>
            <div class="mt-1 space-y-2">
              <% a.comments.each do |c| %>
                <div class="rounded-lg border border-line-soft p-2">
                  <div class="flex items-center gap-1.5"><%= avatar(c.author, size: 20) %><span class="text-xs font-bold text-ink"><%= c.author&.name %></span><span class="text-[10px] text-line"><%= c.author&.role_short %></span></div>
                  <p class="mt-1 text-[12.5px] text-ink/85"><%= c.body %></p>
                </div>
              <% end %>
            </div>
            <%= form_with url: annotation_comments_path(a), class: "mt-2 flex gap-1" do %>
              <%= text_field_tag :body, nil, placeholder: "코멘트 추가", class: "min-w-0 flex-1 rounded border border-line-soft px-2 py-1 text-xs" %>
              <%= submit_tag "등록", class: "cursor-pointer rounded bg-cooa px-2 py-1 text-xs font-bold text-white" %>
            <% end %>
          </div>
          <%# 반영 확인(검토 ②) — 리뷰어(resolve_feedback) %>
          <% if policy(a).resolve_feedback? %>
            <div class="border-t border-line-soft p-3">
              <% if a.resolved? %>
                <div class="flex items-center justify-between text-xs">
                  <span class="font-bold" style="color:#5f8f2e">✓ <%= a.resolved_in_version&.vlabel || @version.vlabel %>에서 반영 확인</span>
                  <%= button_to "다시 열기", reopen_annotation_path(a), method: :patch, class: "cursor-pointer rounded border border-line px-2 py-1 text-line" %>
                </div>
              <% else %>
                <%= button_to "✓ 반영됨으로 표시", resolve_annotation_path(a, resolved_in_version_id: @version.id), method: :patch,
                      class: "w-full cursor-pointer rounded-lg py-2 text-[13px] font-bold text-white", style: "background:#5f8f2e" %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# 새 피드백 (Shift+드래그 시 표시) %>
      <% if policy(@version).leave_feedback? %>
        <div data-version-feedback-target="newForm" class="hidden flex-1 flex-col border-t border-line-soft p-3">
          <div class="mb-2 flex items-center justify-between">
            <h4 class="text-sm font-bold text-ink">새 피드백 (<%= @version.vlabel %>)</h4>
            <button type="button" data-action="version-feedback#backToList" class="text-xs text-line">취소</button>
          </div>
          <%= form_with url: component_version_annotations_path(@version), class: "space-y-2" do %>
            <%= hidden_field_tag :box_x, nil, data: { version_feedback_target: "newX" } %>
            <%= hidden_field_tag :box_y, nil, data: { version_feedback_target: "newY" } %>
            <%= hidden_field_tag :box_w, nil, data: { version_feedback_target: "newW" } %>
            <%= hidden_field_tag :box_h, nil, data: { version_feedback_target: "newH" } %>
            <select name="category" class="w-full rounded border border-line-soft px-2 py-1 text-sm">
              <option>오탈자</option><option>인허가</option><option>디자인</option><option>기타</option>
            </select>
            <%= text_area_tag :body, nil, rows: 3, placeholder: "수정 요청 내용", class: "w-full rounded border border-line-soft px-2 py-1 text-sm" %>
            <%= submit_tag "피드백 추가", class: "w-full cursor-pointer rounded-lg bg-cooa py-2 text-[13px] font-bold text-white" %>
          <% end %>
        </div>
      <% end %>

      <%# 버전 리뷰(검토 단위 ①: 버전 레벨) — 리뷰어가 이 버전을 검토 확인 / 변경 요청 %>
      <%= render "component_versions/review_panel" %>
    </aside>
  </div>

  <%# 하단 액션바 %>
  <div class="flex flex-wrap items-center justify-center gap-2.5 border-t border-line-soft bg-white px-6 py-3">
    <%= link_to edit_component_version_path(@version),
          class: "inline-flex items-center gap-1.5 rounded-lg border border-line px-4 py-2 text-[14px] font-bold text-ink transition hover:border-cooa hover:text-cooa" do %>
      <%= ui_icon "settings", size: 15 %> 편집
    <% end %>
    <% if @prev %>
      <%= link_to comparison_path(from_id: @prev.id, to_id: @version.id),
            class: "inline-flex items-center gap-1.5 rounded-lg border border-line px-4 py-2 text-[14px] font-bold text-ink transition hover:border-cooa hover:text-cooa" do %>
        <%= ui_icon "layers", size: 15 %> <%= @prev.vlabel.upcase %>와 비교
      <% end %>
    <% end %>
    <%= link_to screening_component_version_path(@version),
          class: "bg-cooa-gradient inline-flex items-center gap-1.5 rounded-lg px-5 py-2 text-[14px] font-bold text-white" do %>
      <%= ui_icon "spark", size: 15 %> 인허가 스크리닝
    <% end %>
  </div>
</div>
