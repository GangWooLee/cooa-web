<% content_for :title, "#{@component.display_name} #{@version.vlabel} · #{@product.code}" %>
<div class="flex h-full flex-col">
  <%# 헤더: 브레드크럼 + 버전 스위처 + 이전/다음 %>
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-line-soft px-6 py-3">
    <div class="flex items-center gap-2 text-note">
      <%= node_breadcrumb(@product, trailing: "#{@component.display_name} #{@version.vlabel}") %>
      <% if @version.current? %>
        <span class="rounded bg-tint px-1.5 py-0.5 text-caption font-bold text-muted">현재 버전</span>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <%# 형제 버전 스위처 (클릭 = 해당 버전 파일 보기) %>
      <div class="flex items-center gap-1">
        <% @siblings.each do |sib| %>
          <%= link_to component_version_path(sib), title: "#{sib.vlabel} 보기",
                class: "shrink-0 rounded-lg p-0.5 transition hover:bg-accent hover:ring-2 hover:ring-cooa/40 #{'ring-2 ring-cooa' if sib.id == @version.id}" do %>
            <%= version_chip(sib.vlabel, size: 28, active: sib.id == @version.id) %>
          <% end %>
        <% end %>
      </div>
      <%= ui_button variant: :secondary, size: :sm, href: new_component_component_version_path(@component), title: "새 버전 추가", class: "ml-1" do %>
        <%= ui_icon "plus", size: 14 %> 새 버전
      <% end %>
    </div>
  </div>

  <%# 본문: 좌 아트워크(피드백 박스·Shift+드래그) / 우 메타+피드백+리뷰 %>
  <div data-controller="version-feedback"
       data-action="artwork-viewer:focus->version-feedback#onFocus artwork-viewer:draw->version-feedback#onDraw"
       class="flex min-h-0 flex-1 flex-col lg:flex-row">
    <div class="min-h-0 min-w-0 flex-1 p-3" style="min-height:380px">
      <% if artwork?(@version) %>
        <%= render "shared/artwork_viewer", image_src: artwork_src(@version),
              is_pdf: @version.artwork_pdf?, thumb_src: artwork_thumb_src(@version),
              worker_src: asset_path("pdfjs.worker.min.js"),
              boxes: annotation_boxes(@annotations), drawable: policy(@version).leave_feedback?, zoom: true %>
      <% else %>
        <div class="flex h-full flex-col items-center justify-center gap-3 rounded-xl border border-dashed border-line bg-tint-2 text-muted">
          <%= ui_icon "doc", size: 32, klass: "text-muted" %>
          <p>아트워크 이미지 없음 · <%= @component.display_name %> <%= @version.vlabel %></p>
          <%= ui_button "파일 추가", size: :sm, href: edit_component_version_path(@version) %>
        </div>
      <% end %>
    </div>

    <aside class="flex w-full shrink-0 flex-col border-t border-line bg-white lg:w-[380px] lg:border-l lg:border-t-0"
           data-controller="pane-switch">
      <%# aside 탭(피드백 기본|정보) — reviews/index 칩 패턴. pane-switch가 활성 패널만 표시(hidden 토글) + 탭
          aria-selected/색 전환. version-feedback와 완전 독립(그 타깃 list/detail/newForm은 불건드림). %>
      <div role="tablist" class="flex shrink-0 items-center gap-1.5 border-b border-line-soft p-2 text-meta">
        <button type="button" role="tab" aria-selected="true" aria-controls="pane-feedback"
                data-pane-switch-target="tab" data-pane="feedback" data-action="pane-switch#select"
                class="rounded-full px-2.5 py-1 font-medium transition bg-cooa text-white">
          피드백 <%= @annotations.size %>
        </button>
        <button type="button" role="tab" aria-selected="false" aria-controls="pane-info"
                data-pane-switch-target="tab" data-pane="info" data-action="pane-switch#select"
                class="rounded-full px-2.5 py-1 font-medium transition bg-tint text-muted">
          정보
        </button>
      </div>

      <%# 정보 패널(기본 숨김) — 메타(컴팩트) %>
      <div id="pane-info" role="tabpanel" data-pane-switch-target="pane" data-pane="info" class="hidden min-h-0 flex-1 overflow-auto">
      <div class="border-b border-line-soft p-4">
        <div class="flex items-center gap-2">
          <%= version_chip(@version.vlabel, size: 34, active: @version.current?) %>
          <div class="min-w-0">
            <div class="text-section font-bold text-ink"><%= @component.display_name %> <%= @version.vlabel %></div>
            <div class="text-meta text-muted"><%= @product.code %> · <%= @product.name %></div>
          </div>
        </div>
        <% if @version.change_reason.present? %>
          <div class="mt-3 rounded-lg bg-accent p-3">
            <div class="text-caption font-bold text-cooa">변경사유</div>
            <p class="mt-1 text-body leading-relaxed text-ink/85"><%= @version.change_reason %></p>
          </div>
        <% end %>
        <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5 text-body">
          <% if @version.created_by %>
            <dt class="font-bold text-muted">작성자</dt>
            <dd class="flex items-center gap-1.5"><%= avatar(@version.created_by, size: 20) %><span class="text-ink"><%= @version.created_by.name %></span></dd>
          <% end %>
          <dt class="font-bold text-muted">생성일</dt>
          <dd class="text-ink"><%= @version.created_at.strftime("%Y.%m.%d %H:%M") %></dd>
          <% if @version.ingredients.any? %>
            <dt class="font-bold text-muted">전성분</dt>
            <dd class="text-ink"><%= @version.ingredients.size %>종</dd>
          <% end %>
        </dl>
      </div>
      </div>

      <%# 피드백 패널(기본 표시) — 리스트/상세/새폼(data-target·data-seq·문구 불변, 위치만 패널 안) %>
      <div id="pane-feedback" role="tabpanel" data-pane-switch-target="pane" data-pane="feedback" class="flex min-h-0 flex-1 flex-col">
      <%# 목록 + 상세 — shared/_feedback_panel(M4 공용). 버전 뷰: 남기기 안내 헤더 · diff/첨부 없음 ·
          resolve는 policy(a).resolve_feedback? 게이트(@version 기준). 새 피드백 폼은 화면 고유(아래). %>
      <% subtitle = capture do %><% if policy(@version).leave_feedback? %>아트워크에서 <b>영역 표시</b> 버튼(또는 <b>Shift+드래그</b>)으로 영역을 지정해 남기세요 · <% end %><b class="text-ink"><%= @annotations.count(&:resolved?) %> 반영</b> / <b class="text-cooa"><%= @annotations.count(&:open?) %> 미반영</b><% end %>
      <%= render "shared/feedback_panel", controller: "version-feedback", annotations: @annotations,
            list_subtitle: subtitle, empty_state: true,
            focus_hint: "← 캔버스에서 이 영역이 확대됩니다.", thread_class: "mt-1",
            show_diff: false, show_attachment: false, resolve_gated: true,
            resolve_version: @version, resolve_label: "반영됨으로 표시", resolved_fallback: @version %>

      <%# 새 피드백 (Shift+드래그 시 표시) %>
      <% if policy(@version).leave_feedback? %>
        <div data-version-feedback-target="newForm" class="hidden flex-1 flex-col border-t border-line-soft p-3">
          <div class="mb-2 flex items-center justify-between">
            <h4 class="text-note font-bold text-ink">새 피드백 (<%= @version.vlabel %>)</h4>
            <button type="button" data-action="version-feedback#backToList" class="text-meta text-muted">취소</button>
          </div>
          <%= form_with url: component_version_annotations_path(@version), class: "space-y-2" do %>
            <%= hidden_field_tag :box_x, nil, data: { version_feedback_target: "newX" } %>
            <%= hidden_field_tag :box_y, nil, data: { version_feedback_target: "newY" } %>
            <%= hidden_field_tag :box_w, nil, data: { version_feedback_target: "newW" } %>
            <%= hidden_field_tag :box_h, nil, data: { version_feedback_target: "newH" } %>
            <select name="category" class="w-full rounded border border-line-soft px-2 py-1 text-note">
              <option>오탈자</option><option>인허가</option><option>디자인</option><option>기타</option>
            </select>
            <%= text_area_tag :body, nil, rows: 3, placeholder: "수정 요청 내용", class: "w-full rounded border border-line-soft px-2 py-1 text-note" %>
            <%= ui_button "피드백 추가", type: "submit", class: "w-full" %>
          <% end %>
        </div>
      <% end %>
      </div>

      <%# 버전 리뷰(하단 고정 details) — 리뷰어가 이 버전을 검토 확인 / 변경 요청 %>
      <%= render "component_versions/review_panel" %>
    </aside>
  </div>

  <%# 하단 액션바 — 검토 확인이 이 버전의 primary CTA(위계 교정: 구 aside 매몰). 편집=ghost·비교=secondary,
      스크리닝은 확인 CTA가 뜰 때만 secondary로 강등(단일 primary 유지). 권한·경고 조건은 _review_panel과 동일. %>
  <% show_confirm = @review.state == :pending && policy(@review.request).confirm_review? %>
  <div class="flex flex-wrap items-center justify-center gap-2.5 border-t border-line-soft bg-white px-6 py-3">
    <%= ui_button variant: :ghost, href: edit_component_version_path(@version) do %>
      <%= ui_icon "settings", size: 15 %> 편집
    <% end %>
    <% if @prev %>
      <%= ui_button variant: :secondary, href: comparison_path(from_id: @prev.id, to_id: @version.id) do %>
        <%= ui_icon "layers", size: 15 %> <%= @prev.vlabel %>와 비교
      <% end %>
    <% end %>
    <%= ui_button variant: (show_confirm ? :secondary : :primary), href: screening_component_version_path(@version) do %>
      <%= ui_icon "spark", size: 15 %> 인허가 스크리닝
    <% end %>
    <% if show_confirm %>
      <% confirm_form = { class: "inline-flex" } %>
      <% confirm_form[:data] = { turbo_confirm: @review.confirm_warning } if @review.confirm_warning %>
      <%= button_to confirm_approval_request_path(@review.request), form: confirm_form, class: ui_button_classes(variant: :primary) do %>
        <%= ui_icon "check", size: 15, stroke: 2.4 %> 검토 확인
      <% end %>
    <% end %>
  </div>
</div>
