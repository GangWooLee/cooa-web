<% content_for :title, "새 버전 · #{@component.product.code}" %>
<div class="mx-auto max-w-xl px-5 py-8">
  <div class="mb-5">
    <div class="text-note"><%= node_breadcrumb(@component.product, trailing: "#{@component.display_name} 새 버전") %></div>
    <h1 class="mt-2 text-display font-bold text-ink"><%= @component.display_name %> 새 버전 추가</h1>
    <p class="text-body text-muted">V<%= (@component.component_versions.maximum(:version_number) || 0) + 1 %> 로 추가됩니다.</p>
  </div>
  <%= render "form" %>
</div>
