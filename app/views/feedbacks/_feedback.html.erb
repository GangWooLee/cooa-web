<div id="feedback-<%= feedback.id %>" class="rounded-xl border p-2.5" style="border-color:#e3c9e9">
  <div class="flex items-center gap-1.5">
    <%= avatar(feedback.author, size: 22) %>
    <span class="text-[13px] font-bold text-ink"><%= feedback.author.name %></span>
    <span class="text-[11px] text-line"><%= feedback.author.role_short %></span>
  </div>
  <p class="mt-1 text-[12.5px] leading-snug text-ink/85"><%= feedback.body %></p>
  <% if feedback.attachment_name.present? %>
    <div class="mt-1 inline-flex items-center gap-1 rounded bg-[#cadfff] px-1.5 py-0.5 text-[11px] text-ink">
      <%= ui_icon "external", size: 11 %><%= feedback.attachment_name %>
    </div>
  <% end %>
  <div class="mt-1 text-[11px] text-line">답글 달기</div>
</div>
