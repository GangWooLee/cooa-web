<% content_for :title, "#{@product.name}#{@product.code ? " · #{@product.code}" : ""}" %>
<% if turbo_frame_request? %>
  <%# 프레임 요청(대시보드 행/사이드바 클릭) → 드로어에 상세만 스왑 %>
  <%= turbo_frame_tag "detail", class: "flex h-full min-h-0 flex-col" do %>
    <%= render "products/detail", product: @product %>
  <% end %>
<% else %>
  <%# 풀 요청(직접 URL/브레드크럼 등) → 대시보드 셸 + 드로어 열림 %>
  <%= render "dashboard/shell", detail_product: @product %>
<% end %>
