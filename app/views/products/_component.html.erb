<%# 구성요소 버전 타임라인 — 노드=인허가 스크리닝, 연결선 ▾=변경사유 펼침(패널 내 비교 열기) %>
<% versions = component.component_versions.sort_by(&:version_number) %>
<% cur = component.current_version %>
<div class="border-b border-line-soft py-4 last:border-0">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:gap-4">
    <%# 구성요소명 + 현재 버전 %>
    <div class="flex shrink-0 items-center gap-2 sm:w-[132px] sm:pt-1">
      <%= ui_icon "layers", size: 16, klass: "shrink-0 text-cooa" %>
      <span class="text-sm font-bold text-ink"><%= component.type_label %></span>
      <% if cur %><span class="rounded bg-tint px-1.5 py-0.5 text-[10px] font-bold text-line">현재 <%= cur.vlabel.upcase %></span><% end %>
    </div>

    <%# 타임라인 %>
    <% if versions.any? %>
      <div data-controller="version-timeline" class="min-w-0 flex-1">
        <div class="flex items-center overflow-x-auto pb-1">
          <% versions.each_with_index do |v, i| %>
            <% if i.positive? %>
              <%# 연결선 + (변경사유 있으면) 펼침 토글 %>
              <div class="flex shrink-0 items-center">
                <span class="h-px w-3 bg-line sm:w-5"></span>
                <% if v.change_reason.present? %>
                  <button type="button"
                          data-action="version-timeline#toggle" data-version-timeline-index-param="<%= i %>"
                          data-version-timeline-target="dot" data-index="<%= i %>"
                          aria-expanded="false" aria-controls="reason-<%= component.id %>-<%= i %>"
                          aria-label="<%= versions[i - 1].vlabel.upcase %>→<%= v.vlabel.upcase %> 변경사유 펼치기"
                          title="<%= versions[i - 1].vlabel.upcase %>→<%= v.vlabel.upcase %> 변경사유 펼치기"
                          class="flex h-6 w-6 items-center justify-center rounded-full border border-line-soft bg-white text-line transition hover:border-cooa hover:text-cooa focus-visible:border-cooa focus-visible:text-cooa focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cooa/40">
                    <%= ui_icon "caret", size: 14 %>
                  </button>
                <% else %>
                  <span class="h-1.5 w-1.5 rounded-full bg-line"></span>
                <% end %>
                <span class="h-px w-3 bg-line sm:w-5"></span>
              </div>
            <% end %>
            <%# 버전 노드 = 인허가 스크리닝 %>
            <%= link_to screening_component_version_path(v), title: "#{v.vlabel.upcase} 인허가 스크리닝",
                  class: "shrink-0 rounded-lg p-0.5 transition hover:bg-accent hover:ring-2 hover:ring-cooa/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cooa/40" do %>
              <%= version_chip(v.vlabel.upcase, size: 30, active: v.current?) %>
            <% end %>
          <% end %>
        </div>

        <%# 변경사유 펼침 패널 (연결선별, 기본 숨김) %>
        <% versions.each_with_index do |v, i| %>
          <% next unless i.positive? && v.change_reason.present? %>
          <div data-version-timeline-target="panel" data-index="<%= i %>" id="reason-<%= component.id %>-<%= i %>" class="hidden">
            <div class="mt-2.5 max-w-xl rounded-xl border border-line-soft bg-tint-2 p-3">
              <div class="flex items-center gap-2">
                <span class="rounded-md bg-cooa px-1.5 py-0.5 text-[10px] font-bold text-white"><%= versions[i - 1].vlabel.upcase %> → <%= v.vlabel.upcase %></span>
                <span class="text-[11px] font-bold text-line">변경사유</span>
              </div>
              <p class="mt-2 text-[13px] leading-relaxed text-ink/85"><%= v.change_reason %></p>
              <%= link_to comparison_path(from_id: versions[i - 1].id, to_id: v.id),
                    class: "mt-2.5 inline-flex items-center gap-1.5 rounded-lg border border-cooa px-3 py-1.5 text-[12px] font-bold text-cooa transition hover:bg-cooa hover:text-white" do %>
                <%= ui_icon "layers", size: 13 %> 비교 열기
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <span class="text-[13px] text-line sm:pt-1">버전 없음</span>
    <% end %>
  </div>
</div>
