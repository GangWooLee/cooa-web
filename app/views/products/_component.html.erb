<%# 구성요소 버전 타임라인 — 노드=슬롯 선택(드래그/클릭), 연결점=빨강, ▾=변경사유(담당자별) %>
<% versions = component.component_versions.sort_by(&:version_number) %>
<% cur = component.current_version %>
<div class="border-b border-line-soft py-4 last:border-0">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:gap-4">
    <%# 구성요소명 + 현재 버전 %>
    <div class="flex shrink-0 items-center gap-2 sm:w-[132px] sm:pt-2.5">
      <%= ui_icon "layers", size: 16, klass: "shrink-0 text-cooa" %>
      <span class="text-sm font-bold text-ink"><%= component.type_label %></span>
      <% if cur %><span class="rounded bg-tint px-1.5 py-0.5 text-[10px] font-bold text-line">현재 <%= cur.vlabel.upcase %></span><% end %>
    </div>

    <%# 타임라인 %>
    <% if versions.any? %>
      <div data-controller="version-timeline" class="min-w-0 flex-1">
        <%# 호버 ring 안 잘리게 패딩 + 슬림 스크롤바 %>
        <div class="flex items-center overflow-x-auto scrollbar-slim px-1 py-2">
          <% versions.each_with_index do |v, i| %>
            <% if i.positive? %>
              <%# 연결선 + (변경사유 있으면) ▾ 토글 / 없으면 빨간 점 %>
              <div class="flex shrink-0 items-center">
                <span class="h-px w-3 bg-line-soft sm:w-5"></span>
                <% if v.change_reason.present? %>
                  <button type="button"
                          data-action="version-timeline#toggle" data-version-timeline-index-param="<%= i %>"
                          data-version-timeline-target="dot" data-index="<%= i %>"
                          aria-expanded="false" aria-controls="reason-<%= component.id %>-<%= i %>"
                          aria-label="<%= versions[i - 1].vlabel.upcase %>→<%= v.vlabel.upcase %> 변경사유 펼치기"
                          title="<%= versions[i - 1].vlabel.upcase %>→<%= v.vlabel.upcase %> 변경사유 펼치기"
                          class="flex h-6 w-6 items-center justify-center rounded-full border border-line-soft bg-white text-line transition hover:border-cooa hover:text-cooa focus-visible:border-cooa focus-visible:text-cooa focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cooa/40">
                    <%= ui_icon "caret", size: 14 %>
                  </button>
                <% else %>
                  <span class="h-2 w-2 rounded-full bg-cooa/70"></span>
                <% end %>
                <span class="h-px w-3 bg-line-soft sm:w-5"></span>
              </div>
            <% end %>
            <%# 버전 노드 = 클릭: 파일 보기 / 드래그: 슬롯 채우기 %>
            <button type="button" draggable="true" data-version-select-target="version"
                    data-vid="<%= v.id %>" data-vlabel="<%= v.vlabel.upcase %>" data-comp="<%= component.id %>"
                    data-action="dragstart->version-select#dragstart click->version-select#view"
                    title="<%= v.vlabel.upcase %> — 클릭: 파일 보기 · 드래그: 슬롯 채우기"
                    class="shrink-0 cursor-pointer rounded-lg p-0.5 transition hover:bg-accent hover:ring-2 hover:ring-cooa/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cooa/40 active:cursor-grabbing">
              <%= version_chip(v.vlabel.upcase, size: 30, active: v.current?) %>
            </button>
          <% end %>
          <%# + 새 버전 (전체 페이지 폼 — 드로어 프레임 탈출) %>
          <span class="h-px w-3 shrink-0 bg-line-soft sm:w-5"></span>
          <%= link_to new_component_component_version_path(component), data: { turbo_frame: "_top" },
                title: "#{component.type_label}에 새 버전 추가",
                class: "flex h-[30px] w-[30px] shrink-0 items-center justify-center rounded-md border border-dashed border-line text-line transition hover:border-cooa hover:text-cooa" do %>
            <%= ui_icon "plus", size: 16 %>
          <% end %>
        </div>

        <%# 변경사유 콜아웃 (연결선별, 기본 숨김) — 담당자별 피드백(어노테이션) %>
        <% versions.each_with_index do |v, i| %>
          <% next unless i.positive? && v.change_reason.present? %>
          <% anns = versions[i - 1].annotations.sort_by { |a| [a.seq || 0, a.position || 0, a.id] } %>
          <div data-version-timeline-target="panel" data-index="<%= i %>" id="reason-<%= component.id %>-<%= i %>" class="hidden">
            <div class="ml-1 mt-3 max-w-xl rounded-xl border border-cooa/30 bg-accent p-3">
              <div class="flex items-center gap-2">
                <span class="rounded-md bg-cooa px-1.5 py-0.5 text-[10px] font-bold text-white"><%= versions[i - 1].vlabel.upcase %> → <%= v.vlabel.upcase %></span>
                <span class="text-[11px] font-bold text-cooa">변경사유</span>
              </div>
              <% if anns.any? %>
                <ul class="mt-2 space-y-1.5">
                  <% anns.each do |a| %>
                    <li class="flex items-center gap-2">
                      <%= avatar(a.created_by, size: 18) %>
                      <span class="min-w-0 flex-1 truncate text-[12.5px] text-ink/85"><%= a.comments.first&.body.presence || [a.before_text, a.after_text].compact.join(" → ").presence || a.category %></span>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="mt-2 text-[13px] leading-relaxed text-ink/85"><%= v.change_reason %></p>
              <% end %>
              <%= link_to comparison_path(from_id: versions[i - 1].id, to_id: v.id),
                    class: "mt-2.5 inline-flex items-center gap-1.5 rounded-lg border border-cooa bg-white px-3 py-1.5 text-[12px] font-bold text-cooa transition hover:bg-cooa hover:text-white" do %>
                <%= ui_icon "layers", size: 13 %> 비교 열기
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <span class="text-[13px] text-line sm:pt-2.5">버전 없음</span>
    <% end %>
  </div>
</div>
