<%# 인라인 편집 메타 필드 — locals: product, label, attr, kind(:text/:date/:select), display, options(select용) %>
<dt class="font-bold text-line"><%= label %></dt>
<dd data-controller="inline-edit" class="min-w-0">
  <span data-inline-edit-target="display" data-action="click->inline-edit#edit" title="클릭하여 수정"
        class="cursor-text rounded px-1 text-ink transition hover:bg-white/70 hover:text-cooa"><%= display.presence || "None" %></span>
  <%= form_with model: product, url: product_path(product), method: :patch,
        data: { turbo_frame: "_top", "inline-edit-target": "form" }, class: "hidden" do |f| %>
    <%= hidden_field_tag :inline, 1 %>
    <% if kind == :text %>
      <%= f.text_field attr, data: { "inline-edit-target": "input", action: "keydown->inline-edit#keydown blur->inline-edit#save" },
            class: "w-40 rounded border border-cooa px-1.5 py-0.5 text-[13px] focus:outline-none" %>
    <% elsif kind == :date %>
      <%= f.date_field attr, data: { "inline-edit-target": "input", action: "change->inline-edit#change blur->inline-edit#save" },
            class: "rounded border border-cooa px-1.5 py-0.5 text-[13px] focus:outline-none" %>
    <% elsif kind == :select %>
      <%= f.select attr, options, {}, data: { "inline-edit-target": "input", action: "change->inline-edit#change blur->inline-edit#save" },
            class: "rounded border border-cooa px-1.5 py-0.5 text-[13px] focus:outline-none" %>
    <% end %>
  <% end %>
</dd>
